{id:"api-2014-spells-blight",name:"Blight",content:[{id:"Title",content:"Blight"},{id:"StatGrid",content:[{title:"Level",content:"4"},{title:"Casting Time",content:"1 action"},{title:"Range",content:"30 feet"},{title:"Components",content:"V, S"},{title:"Duration",content:"Instantaneous"},{title:"School",content:"Necromancy"},{title:"Save",content:"CON Save"},{title:"Damage",content:"Necrotic"}]},{id:"Subtitle",content:"Effect"},{id:"MultiText",content:["Necromantic energy washes over a creature of your choice that you can see within range, draining moisture and vitality from it. The target must make a constitution saving throw. The target takes 8d8 necrotic damage on a failed save, or half as much damage on a successful one. The spell has no effect on undead or constructs.","If you target a plant creature or a magical plant, it makes the saving throw with disadvantage, and the spell deals maximum damage to it.","If you target a nonmagical plant that isn't a creature, such as a tree or shrub, it doesn't make a saving throw; it simply withers and dies."]},{id:"Subtitle",content:"At higher levels"},{id:"MultiText",content:["When you cast this spell using a spell slot of 5th level of higher, the damage increases by 1d8 for each slot level above 4th."]},{id:"Table",content:[["slot level","4","5","6","7","8","9"],["damage","8d8","9d8","10d8","11d8","12d8","13d8"]]}]}