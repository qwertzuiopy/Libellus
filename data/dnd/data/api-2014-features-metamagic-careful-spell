{id:"api-2014-features-metamagic-careful-spell",name:"Metamagic: Careful Spell",content:[{id:"Title",content:"Metamagic: Careful Spell"},{id:"StatGrid",content:[{title:"Level",content:"3"}]},{id:"MultiText",content:["When you cast a spell that forces other creatures to make a saving throw, you can protect some of those creatures from the spell's full force. To do so, you spend 1 sorcery point and choose a number of those creatures up to your Charisma modifier (minimum of one creature). A chosen creature automatically succeeds on its saving throw against the spell."]},{id:"LinkList",content:[{id:"@api-2014-classes-sorcerer",content:""}]}]}