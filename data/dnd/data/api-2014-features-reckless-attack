{id:"api-2014-features-reckless-attack",name:"Reckless Attack",content:[{id:"Title",content:"Reckless Attack"},{id:"StatGrid",content:[{title:"Level",content:"2"}]},{id:"MultiText",content:["Starting at 2nd level, you can throw aside all concern for defense to attack with fierce desperation. When you make your first attack on your turn, you can decide to attack recklessly. Doing so gives you advantage on melee weapon attack rolls using Strength during this turn, but attack rolls against you have advantage until your next turn."]},{id:"LinkList",content:[{id:"@api-2014-classes-barbarian",content:""}]}]}