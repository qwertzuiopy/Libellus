{id:"api-2014-magic-items-manual-of-quickness-of-action",name:"Manual of Quickness of Action",content:[{id:"Title",content:"Manual of Quickness of Action"},{id:"StatGrid",content:[{title:"Category",content:"Wondrous Items"},{title:"Rarity",content:"Very Rare"}]},{id:"MultiText",content:["Wondrous item, very rare","This book contains coordination and balance exercises, and its words are charged with magic. If you spend 48 hours over a period of 6 days or fewer studying the book's contents and practicing its guidelines, your Dexterity score increases by 2, as does your maximum for that score. The manual then loses its magic, but regains it in a century."]}]}