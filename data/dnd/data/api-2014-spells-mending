{id:"api-2014-spells-mending",name:"Mending",content:[{id:"Title",content:"Mending"},{id:"StatGrid",content:[{title:"Level",content:"0"},{title:"Casting Time",content:"1 minute"},{title:"Range",content:"Touch"},{title:"Components",content:"V, S, M"},{title:"Duration",content:"Instantaneous"},{title:"School",content:"Transmutation"}]},{id:"Subtitle",content:"Effect"},{id:"MultiText",content:["This spell repairs a single break or tear in an object you touch, such as a broken key, a torn cloak, or a leaking wineskin. As long as the break or tear is no longer than 1 foot in any dimension, you mend it, leaving no trace of the former damage.","This spell can physically repair a magic item or construct, but the spell can't restore magic to such an object."]}]}