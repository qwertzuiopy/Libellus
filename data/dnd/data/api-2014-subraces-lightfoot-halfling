{id:"api-2014-subraces-lightfoot-halfling",name:"Lightfoot Halfling",content:[{id:"Title",content:"Lightfoot Halfling"},{id:"StatGrid",content:[{title:"Race",content:"@api-2014-races-halfling"}]},{id:"MultiText",content:["As a lightfoot halfling, you can easily hide from notice, even using other people as cover. You're inclined to be affable and get along well with others. Lightfoots are more prone to wanderlust than other halflings, and often dwell alongside other races or take up a nomadic life."]},{id:"StatList",content:[{title:"Ability bonuses",content:["+1 CHA"]}]}]}