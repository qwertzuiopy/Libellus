{id:"api-2014-races-half-elf",name:"Half-Elf",content:[{id:"Title",content:"Half-Elf"},{id:"StatGrid",content:[{title:"Speed",content:"30ft"},{title:"Size",content:"Medium"}]},{id:"MultiText",content:["***Age.***Half-elves mature at the same rate humans do and reach adulthood around the age of 20. They live much longer than humans, however, often exceeding 180 years.","***Alignment.***Half-elves share the chaotic bent of their elven heritage. They value both personal freedom and creative expression, demonstrating neither love of leaders nor desire for followers. They chafe at rules, resent others' demands, and sometimes prove unreliable, or at least unpredictable.","***Languages.***You can speak, read, and write Common, Elvish, and one extra language of your choice.","***Size.***Half-elves are about the same size as humans, ranging from 5 to 6 feet tall. Your size is Medium."]},{id:"StatList",content:[{title:"Ability bonuses",content:["+2 CHA"]},{title:"Languages",content:["Common","Elvish"]}]},{id:"Subtitle",content:"Traits"},{id:"LinkList",content:[{id:"@api-2014-traits-darkvision",content:""},{id:"@api-2014-traits-fey-ancestry",content:""},{id:"@api-2014-traits-skill-versatility",content:""}]},{id:"Subtitle",content:"Subraces"},{id:"LinkList",content:[]}]}