{id:"api-2014-spells-poison-spray",name:"Poison Spray",content:[{id:"Title",content:"Poison Spray"},{id:"StatGrid",content:[{title:"Level",content:"0"},{title:"Casting Time",content:"1 action"},{title:"Range",content:"10 feet"},{title:"Components",content:"V, S"},{title:"Duration",content:"Instantaneous"},{title:"School",content:"Conjuration"},{title:"Save",content:"CON Save"},{title:"Damage",content:"Poison"}]},{id:"Subtitle",content:"Effect"},{id:"MultiText",content:["You extend your hand toward a creature you can see within range and project a puff of noxious gas from your palm. The creature must succeed on a constitution saving throw or take 1d12 poison damage.","This spell's damage increases by 1d12 when you reach 5th level (2d12), 11th level (3d12), and 17th level (4d12)."]},{id:"Table",content:[["character level","1","5","11","17"],["damage","1d12","2d12","3d12","4d12"]]}]}