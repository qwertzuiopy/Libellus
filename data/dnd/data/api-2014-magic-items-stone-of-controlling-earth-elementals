{id:"api-2014-magic-items-stone-of-controlling-earth-elementals",name:"Stone of Controlling Earth Elementals",content:[{id:"Title",content:"Stone of Controlling Earth Elementals"},{id:"StatGrid",content:[{title:"Category",content:"Wondrous Items"},{title:"Rarity",content:"Rare"}]},{id:"MultiText",content:["Wondrous item, rare","If the stone is touching the ground, you can use an action to speak its command word and summon an earth elemental, as if you had cast the conjure elemental spell. The stone can't be used this way again until the next dawn. The stone weighs 5 pounds."]}]}