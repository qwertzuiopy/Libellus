{id:"api-2014-spells-arcane-sword",name:"Arcane Sword",content:[{id:"Title",content:"Arcane Sword"},{id:"StatGrid",content:[{title:"Level",content:"7"},{title:"Casting Time",content:"1 action"},{title:"Range",content:"60 feet"},{title:"Components",content:"V, S, M"},{title:"Duration",content:"Up to 1 minute"},{title:"School",content:"Evocation"},{title:"Attack",content:"melee"},{title:"Damage",content:"Force"}]},{id:"Subtitle",content:"Effect"},{id:"MultiText",content:["You create a sword-shaped plane of force that hovers within range. It lasts for the duration.","When the sword appears, you make a melee spell attack against a target of your choice within 5 feet of the sword. On a hit, the target takes 3d10 force damage. Until the spell ends, you can use a bonus action on each of your turns to move the sword up to 20 feet to a spot you can see and repeat this attack against the same target or a different one."]},{id:"Table",content:[["slot level","7"],["damage","3d10"]]}]}