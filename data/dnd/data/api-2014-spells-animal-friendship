{id:"api-2014-spells-animal-friendship",name:"Animal Friendship",content:[{id:"Title",content:"Animal Friendship"},{id:"StatGrid",content:[{title:"Level",content:"1"},{title:"Casting Time",content:"1 action"},{title:"Range",content:"30 feet"},{title:"Components",content:"V, S, M"},{title:"Duration",content:"24 hours"},{title:"School",content:"Enchantment"},{title:"Save",content:"WIS Save"}]},{id:"Subtitle",content:"Effect"},{id:"MultiText",content:["This spell lets you convince a beast that you mean it no harm. Choose a beast that you can see within range. It must see and hear you. If the beast's Intelligence is 4 or higher, the spell fails. Otherwise, the beast must succeed on a wisdom saving throw or be charmed by you for the spell's duration. If you or one of your companions harms the target, the spells ends."]}]}