{id:"api-2014-ability-scores-con",name:"Constitution",content:[{id:"Title",content:"Constitution"},{id:"MultiText",content:["Constitution measures health, stamina, and vital force.","Constitution checks are uncommon, and no skills apply to Constitution checks, because the endurance this ability represents is largely passive rather than involving a specific effort on the part of a character or monster."]},{id:"LinkList",content:[]}]}