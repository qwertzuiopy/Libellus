{id:"api-2014-spells-hold-monster",name:"Hold Monster",content:[{id:"Title",content:"Hold Monster"},{id:"StatGrid",content:[{title:"Level",content:"5"},{title:"Casting Time",content:"1 action"},{title:"Range",content:"90 feet"},{title:"Components",content:"V, S, M"},{title:"Duration",content:"Up to 1 minute"},{title:"School",content:"Enchantment"},{title:"Save",content:"WIS Save"}]},{id:"Subtitle",content:"Effect"},{id:"MultiText",content:["Choose a creature you can see and reach. The target must make a saving throw of Wisdom or be paralyzed for the duration of the spell. This spell has no effect against the undead. At the end of each round, the target can make a new saving throw of Wisdom. If successful, the spell ends for the creature."]},{id:"Subtitle",content:"At higher levels"},{id:"MultiText",content:["When you cast this spell using a level 6 or higher location, you can target an additional creature for each level of location beyond the fifth. The creatures must be within 30 feet o f each other when you target them."]}]}