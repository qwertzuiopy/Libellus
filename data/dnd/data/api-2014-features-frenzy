{id:"api-2014-features-frenzy",name:"Frenzy",content:[{id:"Title",content:"Frenzy"},{id:"StatGrid",content:[{title:"Level",content:"3"}]},{id:"MultiText",content:["Starting when you choose this path at 3rd level, you can go into a frenzy when you rage. If you do so, for the duration of your rage you can make a single melee weapon attack as a bonus action on each of your turns after this one. When your rage ends, you suffer one level of exhaustion (as described in appendix A)."]},{id:"LinkList",content:[{id:"@api-2014-classes-barbarian",content:""},{id:"@api-2014-subclasses-berserker",content:""}]}]}