{id:"api-2014-equipment-manacles",name:"Manacles",content:[{id:"Title",content:"Manacles"},{id:"StatGrid",content:[{title:"Category",content:"Adventuring Gear"},{title:"Cost",content:"2gp"},{title:"Weight",content:"6lb"},{title:"Type",content:"Standard Gear"}]},{id:"MultiText",content:["These metal restraints can bind a Small or Medium creature. Escaping the manacles requires a successful DC 20 Dexterity check. Breaking them requires a successful DC 20 Strength check.","Each set of manacles comes with one key. Without the key, a creature proficient with thieves' tools can pick the manacles' lock with a successful DC 15 Dexterity check. Manacles have 15 hit points."]}]}