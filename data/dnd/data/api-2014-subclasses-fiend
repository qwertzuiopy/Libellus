{id:"api-2014-subclasses-fiend",name:"Fiend",content:[{id:"Title",content:"Fiend"},{id:"MultiText",content:["You have made a pact with a fiend from the lower planes of existence, a being whose aims are evil, even if you strive against those aims. Such beings desire the corruption or destruction of all things, ultimately including you. Fiends powerful enough to forge a pact include demon lords such as Demogorgon, Orcus, Fraz'Urb-luu, and Baphomet; archdevils such as Asmodeus, Dispater, Mephistopheles, and Belial; pit fiends and balors that are especially mighty; and ultroloths and other lords of the yugoloths."]},{id:"Subtitle",content:"Features"},{id:"StatList",content:[{title:"1.",content:["@api-2014-features-dark-ones-blessing"]},{title:"6.",content:["@api-2014-features-dark-ones-own-luck"]},{title:"10.",content:["@api-2014-features-fiendish-resilience"]},{title:"14.",content:["@api-2014-features-hurl-through-hell"]}]},{id:"LinkList",content:[{id:"api-2014-spells-burning-hands",content:"level  1"},{id:"api-2014-spells-command",content:"level  1"},{id:"api-2014-spells-blindness-deafness",content:"level  3"},{id:"api-2014-spells-scorching-ray",content:"level  3"},{id:"api-2014-spells-fireball",content:"level  5"},{id:"api-2014-spells-stinking-cloud",content:"level  5"},{id:"api-2014-spells-fire-shield",content:"level  7"},{id:"api-2014-spells-wall-of-fire",content:"level  7"},{id:"api-2014-spells-flame-strike",content:"level  9"},{id:"api-2014-spells-hallow",content:"level  9"}]}]}