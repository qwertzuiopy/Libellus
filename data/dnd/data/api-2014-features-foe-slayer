{id:"api-2014-features-foe-slayer",name:"Foe Slayer",content:[{id:"Title",content:"Foe Slayer"},{id:"StatGrid",content:[{title:"Level",content:"20"}]},{id:"MultiText",content:["At 20th level, you become an unparalleled hunter of your enemies. Once on each of your turns, you can add your Wisdom modifier to the attack roll or the damage roll of an attack you make against one of your favored enemies. You can choose to use this feature before or after the roll, but before any effects of the roll are applied."]},{id:"LinkList",content:[{id:"@api-2014-classes-ranger",content:""}]}]}