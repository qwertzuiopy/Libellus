{id:"api-2014-monsters-vampire-spawn",name:"Vampire Spawn",category:"monster",content:[{id:"Title",content:"Vampire Spawn"},{id:"Image",url:"https://www.dnd5eapi.co/api/images/monsters/vampire-spawn.png"},{id:"StatGrid",content:[{title:"Strength",content:"16 / +3"},{title:"Dexterity",content:"16 / +3"},{title:"Constitution",content:"16 / +3"},{title:"Intelligence",content:"11 / 0"},{title:"Wisdom",content:"10 / 0"},{title:"Charisma",content:"12 / +1"},{title:"Alignment",content:"neutral evil"},{title:"Armor Class",content:"15"},{title:"Hit Dice",content:"11d8"},{title:"Type",content:"undead"},{title:"Challenge Rating",content:"5"},{title:"Size",content:"Medium"},{title:"Hit Points",content:"82 / 11d8+33"}]},{id:"StatList",content:[{title:"Speed",content:["30 ft. walk"]},{title:"Languages",content:["the languages it knew in life"]},{title:"Senses",content:["darkvision60 ft."]},{title:"Saving Throws",content:["+6 dex","+3 wis"]},{title:"Skills",content:["+3 perception","+6 stealth"]}]},{id:"Subtitle",content:"Abilities"},{id:"TitledText",content:[{title:"Regeneration",content:"The vampire regains 10 hit points at the start of its turn if it has at least 1 hit point and isn't in sunlight or running water. If the vampire takes radiant damage or damage from holy water, this trait doesn't function at the start of the vampire's next turn."},{title:"Spider Climb",content:"The vampire can climb difficult surfaces, including upside down on ceilings, without needing to make an ability check."},{title:"Vampire Weaknesses",content:"The vampire has the following flaws:
Forbiddance. The vampire can't enter a residence without an invitation from one of the occupants.
Harmed by Running Water. The vampire takes 20 acid damage when it ends its turn in running water.
Stake to the Heart. The vampire is destroyed if a piercing weapon made of wood is driven into its heart while it is incapacitated in its resting place.
Sunlight Hypersensitivity. The vampire takes 20 radiant damage when it starts its turn in sunlight. While in sunlight, it has disadvantage on attack rolls and ability checks."}]},{id:"Subtitle",content:"Actions"},{id:"TitledText",content:[{title:"Multiattack",content:"The vampire makes two attacks, only one of which can be a bite attack."},{title:"Bite",content:"Melee Weapon Attack: +6 to hit, reach 5 ft., one willing creature, or a creature that is grappled by the vampire, incapacitated, or restrained. Hit: 6 (1d6 + 3) piercing damage plus 7 (2d6) necrotic damage. The target's hit point maximum is reduced by an amount equal to the necrotic damage taken, and the vampire regains hit points equal to that amount. The reduction lasts until the target finishes a long rest. The target dies if this effect reduces its hit point maximum to 0."},{title:"Claws",content:"Melee Weapon Attack: +6 to hit, reach 5 ft., one creature. Hit: 8 (2d4 + 3) slashing damage. Instead of dealing damage, the vampire can grapple the target (escape DC 13)."}]}]}