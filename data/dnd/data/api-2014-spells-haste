{id:"api-2014-spells-haste",name:"Haste",content:[{id:"Title",content:"Haste"},{id:"StatGrid",content:[{title:"Level",content:"3"},{title:"Casting Time",content:"1 action"},{title:"Range",content:"30 feet"},{title:"Components",content:"V, S, M"},{title:"Duration",content:"Up to 1 minute"},{title:"School",content:"Transmutation"}]},{id:"Subtitle",content:"Effect"},{id:"MultiText",content:["Choose a willing creature that you can see within range. Until the spell ends, the target's speed is doubled, it gains a +2 bonus to AC, it has advantage on dexterity saving throws, and it gains an additional action on each of its turns. That action can be used only to take the Attack (one weapon attack only), Dash, Disengage, Hide, or Use an Object action.","When the spell ends, the target can't move or take actions until after its next turn, as a wave of lethargy sweeps over it."]}]}