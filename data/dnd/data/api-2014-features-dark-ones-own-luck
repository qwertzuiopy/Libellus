{id:"api-2014-features-dark-ones-own-luck",name:"Dark One's Own Luck",content:[{id:"Title",content:"Dark One's Own Luck"},{id:"StatGrid",content:[{title:"Level",content:"6"}]},{id:"MultiText",content:["Starting at 6th level, you can call on your patron to alter fate in your favor. When you make an ability check or a saving throw, you can use this feature to add a d10 to your roll. You can do so after seeing the initial roll but before any of the roll's effects occur.","Once you use this feature, you can't use it again until you finish a short or long rest."]},{id:"LinkList",content:[{id:"@api-2014-classes-warlock",content:""},{id:"@api-2014-subclasses-fiend",content:""}]}]}