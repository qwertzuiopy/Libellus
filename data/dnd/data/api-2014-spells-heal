{id:"api-2014-spells-heal",name:"Heal",content:[{id:"Title",content:"Heal"},{id:"StatGrid",content:[{title:"Level",content:"6"},{title:"Casting Time",content:"1 action"},{title:"Range",content:"60 feet"},{title:"Components",content:"V, S"},{title:"Duration",content:"Instantaneous"},{title:"School",content:"Evocation"}]},{id:"Subtitle",content:"Effect"},{id:"MultiText",content:["Choose a creature that you can see within range. A surge of positive energy washes through the creature, causing it to regain 70 hit points. This spell also ends blindness, deafness, and any diseases affecting the target. This spell has no effect on constructs or undead."]},{id:"Subtitle",content:"At higher levels"},{id:"MultiText",content:["When you cast this spell using a spell slot of 7th level or higher, the amount of healing increases by 10 for each slot level above 6th."]},{id:"Table",content:[["slot level","6","7","8","9"],["heal","70","80","90","100"]]}]}