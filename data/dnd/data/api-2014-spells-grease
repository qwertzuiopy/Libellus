{id:"api-2014-spells-grease",name:"Grease",content:[{id:"Title",content:"Grease"},{id:"StatGrid",content:[{title:"Level",content:"1"},{title:"Casting Time",content:"1 action"},{title:"Range",content:"60 feet (10ft cube)"},{title:"Components",content:"V, S, M"},{title:"Duration",content:"1 minute"},{title:"School",content:"Conjuration"},{title:"Save",content:"DEX Save"}]},{id:"Subtitle",content:"Effect"},{id:"MultiText",content:["Slick grease covers the ground in a 10-foot square centered on a point within range and turns it into difficult terrain for the duration.","When the grease appears, each creature standing in its area must succeed on a dexterity saving throw or fall prone. A creature that enters the area or ends its turn there must also succeed on a dexterity saving throw or fall prone."]}]}