{id:"api-2014-monsters-doppelganger",name:"Doppelganger",category:"monster",content:[{id:"Title",content:"Doppelganger"},{id:"Image",url:"https://www.dnd5eapi.co/api/images/monsters/doppelganger.png"},{id:"StatGrid",content:[{title:"Strength",content:"11 / 0"},{title:"Dexterity",content:"18 / +4"},{title:"Constitution",content:"14 / +2"},{title:"Intelligence",content:"11 / 0"},{title:"Wisdom",content:"12 / +1"},{title:"Charisma",content:"14 / +2"},{title:"Alignment",content:"unaligned"},{title:"Armor Class",content:"14"},{title:"Hit Dice",content:"8d8"},{title:"Type",content:"monstrosity"},{title:"Subtype",content:"shapechanger"},{title:"Challenge Rating",content:"3"},{title:"Size",content:"Medium"},{title:"Hit Points",content:"52 / 8d8+16"}]},{id:"StatList",content:[{title:"Speed",content:["30 ft. walk"]},{title:"Languages",content:["Common"]},{title:"Senses",content:["darkvision60 ft."]},{title:"Saving Throws",content:[]},{title:"Skills",content:["+6 deception","+3 insight"]}]},{id:"Subtitle",content:"Abilities"},{id:"TitledText",content:[{title:"Shapechanger",content:"The doppelganger can use its action to polymorph into a Small or Medium humanoid it has seen, or back into its true form. Its statistics, other than its size, are the same in each form. Any equipment it is wearing or carrying isn't transformed. It reverts to its true form if it dies."},{title:"Ambusher",content:"In the first round of combat, the doppelganger has advantage on attack rolls against any creature it has surprised."},{title:"Surprise Attack",content:"If the doppelganger surprises a creature and hits it with an attack during the first round of combat, the target takes an extra 10 (3d6) damage from the attack."}]},{id:"Subtitle",content:"Actions"},{id:"TitledText",content:[{title:"Multiattack",content:"The doppelganger makes two melee attacks."},{title:"Slam",content:"Melee Weapon Attack: +6 to hit, reach 5 ft., one target. Hit: 7 (1d6 + 4) bludgeoning damage."},{title:"Read Thoughts",content:"The doppelganger magically reads the surface thoughts of one creature within 60 ft. of it. The effect can penetrate barriers, but 3 ft. of wood or dirt, 2 ft. of stone, 2 inches of metal, or a thin sheet of lead blocks it. While the target is in range, the doppelganger can continue reading its thoughts, as long as the doppelganger's concentration isn't broken (as if concentrating on a spell). While reading the target's mind, the doppelganger has advantage on Wisdom (Insight) and Charisma (Deception, Intimidation, and Persuasion) checks against the target."}]}]}