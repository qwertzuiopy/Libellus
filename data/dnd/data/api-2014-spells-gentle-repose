{id:"api-2014-spells-gentle-repose",name:"Gentle Repose",content:[{id:"Title",content:"Gentle Repose"},{id:"StatGrid",content:[{title:"Level",content:"2"},{title:"Casting Time",content:"1 action"},{title:"Range",content:"Touch"},{title:"Components",content:"V, S, M"},{title:"Duration",content:"10 days"},{title:"School",content:"Necromancy"}]},{id:"Subtitle",content:"Effect"},{id:"MultiText",content:["You touch a corpse or other remains. For the duration, the target is protected from decay and can't become undead.","The spell also effectively extends the time limit on raising the target from the dead, since days spent under the influence of this spell don't count against the time limit of spells such as raise dead."]}]}