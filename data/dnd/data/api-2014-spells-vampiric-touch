{id:"api-2014-spells-vampiric-touch",name:"Vampiric Touch",content:[{id:"Title",content:"Vampiric Touch"},{id:"StatGrid",content:[{title:"Level",content:"3"},{title:"Casting Time",content:"1 action"},{title:"Range",content:"Self"},{title:"Components",content:"V, S"},{title:"Duration",content:"Up to 1 minute"},{title:"School",content:"Necromancy"},{title:"Attack",content:"melee"},{title:"Damage",content:"Necrotic"}]},{id:"Subtitle",content:"Effect"},{id:"MultiText",content:["The touch of your shadow-wreathed hand can siphon life force from others to heal your wounds. Make a melee spell attack against a creature within your reach. On a hit, the target takes 3d6 necrotic damage, and you regain hit points equal to half the amount of necrotic damage dealt. Until the spell ends, you can make the attack again on each of your turns as an action."]},{id:"Subtitle",content:"At higher levels"},{id:"MultiText",content:["When you cast this spell using a spell slot of 4th level or higher, the damage increases by 1d6 for each slot level above 3rd."]},{id:"Table",content:[["slot level","3","4","5","6","7","8","9"],["damage","3d6","4d6","5d6","6d6","7d6","8d6","9d6"]]}]}