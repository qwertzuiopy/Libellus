{id:"api-2014-features-metamagic-empowered-spell",name:"Metamagic: Empowered Spell",content:[{id:"Title",content:"Metamagic: Empowered Spell"},{id:"StatGrid",content:[{title:"Level",content:"3"}]},{id:"MultiText",content:["When you roll damage for a spell, you can spend 1 sorcery point to reroll a number of the damage dice up to your Charisma modifier (minimum of one). You must use the new rolls.","You can use Empowered Spell even if you have already used a different Metamagic option during the casting of the spell."]},{id:"LinkList",content:[{id:"@api-2014-classes-sorcerer",content:""}]}]}