{id:"api-2014-equipment-climbers-kit",name:"Climber's Kit",content:[{id:"Title",content:"Climber's Kit"},{id:"StatGrid",content:[{title:"Category",content:"Adventuring Gear"},{title:"Cost",content:"25gp"},{title:"Weight",content:"12lb"},{title:"Type",content:"Kits"}]},{id:"MultiText",content:["A climber's kit includes special pitons, boot tips, gloves, and a harness. You can use the climber's kit as an action to anchor yourself; when you do, you can't fall more than 25 feet from the point where you anchored yourself, and you can't climb more than 25 feet away from that point without undoing the anchor."]}]}