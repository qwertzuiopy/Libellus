{id:"api-2014-monsters-death-dog",name:"Death Dog",category:"monster",content:[{id:"Title",content:"Death Dog"},{id:"Image",url:"https://www.dnd5eapi.co/api/images/monsters/death-dog.png"},{id:"StatGrid",content:[{title:"Strength",content:"15 / +2"},{title:"Dexterity",content:"14 / +2"},{title:"Constitution",content:"14 / +2"},{title:"Intelligence",content:"3 / -4"},{title:"Wisdom",content:"13 / +1"},{title:"Charisma",content:"6 / -2"},{title:"Alignment",content:"neutral evil"},{title:"Armor Class",content:"12"},{title:"Hit Dice",content:"6d8"},{title:"Type",content:"monstrosity"},{title:"Challenge Rating",content:"1"},{title:"Size",content:"Medium"},{title:"Hit Points",content:"39 / 6d8+12"}]},{id:"StatList",content:[{title:"Speed",content:["40 ft. walk"]},{title:"Languages",content:[""]},{title:"Senses",content:["darkvision120 ft."]},{title:"Saving Throws",content:[]},{title:"Skills",content:["+5 perception","+4 stealth"]}]},{id:"MultiText",content:["A death dog is an ugly two-headed hound that roams plains, and deserts. Hate burns in a death dog’s heart, and a taste for humanoid flesh drives it to attack travelers and explorers. Death dog saliva carries a foul disease that causes a victim’s flesh to slowly rot off the bone."]},{id:"Subtitle",content:"Abilities"},{id:"TitledText",content:[{title:"Two-Headed",content:"The dog has advantage on Wisdom (Perception) checks and on saving throws against being blinded, charmed, deafened, frightened, stunned, or knocked unconscious."}]},{id:"Subtitle",content:"Actions"},{id:"TitledText",content:[{title:"Multiattack",content:"The dog makes two bite attacks."},{title:"Bite",content:"Melee Weapon Attack: +4 to hit, reach 5 ft., one target. Hit: 5 (1d6 + 2) piercing damage. If the target is a creature, it must succeed on a DC 12 Constitution saving throw against disease or become poisoned until the disease is cured. Every 24 hours that elapse, the creature must repeat the saving throw, reducing its hit point maximum by 5 (1d10) on a failure. This reduction lasts until the disease is cured. The creature dies if the disease reduces its hit point maximum to 0."}]}]}