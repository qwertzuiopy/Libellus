{id:"api-2014-spells-goodberry",name:"Goodberry",content:[{id:"Title",content:"Goodberry"},{id:"StatGrid",content:[{title:"Level",content:"1"},{title:"Casting Time",content:"1 action"},{title:"Range",content:"Touch"},{title:"Components",content:"V, S, M"},{title:"Duration",content:"Instantaneous"},{title:"School",content:"Transmutation"}]},{id:"Subtitle",content:"Effect"},{id:"MultiText",content:["Up to ten berries appear in your hand and are infused with magic for the duration. A creature can use its action to eat one berry. Eating a berry restores 1 hit point, and the berry provides enough nourishment to sustain a creature for a day.","The berries lose their potency if they have not been consumed within 24 hours of the casting of this spell."]}]}