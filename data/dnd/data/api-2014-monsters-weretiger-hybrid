{id:"api-2014-monsters-weretiger-hybrid",name:"Weretiger, Hybrid Form",category:"monster",content:[{id:"Title",content:"Weretiger, Hybrid Form"},{id:"Image",url:"https://www.dnd5eapi.co/api/images/monsters/weretiger-hybrid.png"},{id:"StatGrid",content:[{title:"Strength",content:"17 / +3"},{title:"Dexterity",content:"15 / +2"},{title:"Constitution",content:"16 / +3"},{title:"Intelligence",content:"10 / 0"},{title:"Wisdom",content:"13 / +1"},{title:"Charisma",content:"11 / 0"},{title:"Alignment",content:"neutral"},{title:"Armor Class",content:"12"},{title:"Hit Dice",content:"16d8"},{title:"Type",content:"humanoid"},{title:"Subtype",content:"human"},{title:"Challenge Rating",content:"4"},{title:"Size",content:"Medium"},{title:"Hit Points",content:"120 / 16d8+48"}]},{id:"StatList",content:[{title:"Speed",content:["30 ft. walk"]},{title:"Languages",content:["Common"]},{title:"Senses",content:["darkvision60 ft."]},{title:"Saving Throws",content:[]},{title:"Skills",content:["+5 perception","+4 stealth"]}]},{id:"Subtitle",content:"Abilities"},{id:"TitledText",content:[{title:"Shapechanger",content:"The weretiger can use its action to polymorph into a tiger-humanoid hybrid or into a tiger, or back into its true form, which is humanoid. Its statistics, other than its size, are the same in each form. Any equipment it is wearing or carrying isn't transformed. It reverts to its true form if it dies."},{title:"Keen Hearing and Smell",content:"The weretiger has advantage on Wisdom (Perception) checks that rely on hearing or smell."},{title:"Pounce",content:"If the weretiger moves at least 15 feet straight toward a creature and then hits it with a claw attack on the same turn, that target must succeed on a DC 14 Strength saving throw or be knocked prone. If the target is prone, the weretiger can make one bite attack against it as a bonus action."}]},{id:"Subtitle",content:"Actions"},{id:"TitledText",content:[{title:"Multiattack",content:"In humanoid form, the weretiger makes two scimitar attacks or two longbow attacks. In hybrid form, it can attack like a humanoid or make two claw attacks."},{title:"Bite",content:"Melee Weapon Attack: +5 to hit, reach 5 ft., one target. Hit: 8 (1d10 + 3) piercing damage. If the target is a humanoid, it must succeed on a DC 13 Constitution saving throw or be cursed with weretiger lycanthropy."},{title:"Claw",content:"Melee Weapon Attack: +5 to hit, reach 5 ft., one target. Hit: 7 (1d8 + 3) slashing damage."},{title:"Scimitar",content:"Melee Weapon Attack: +5 to hit, reach 5 ft., one target. Hit: 6 (1d6 + 3) slashing damage."},{title:"Longbow",content:"Ranged Weapon Attack: +4 to hit, range 150/600 ft., one target. Hit: 6 (1d8 + 2) piercing damage."}]}]}