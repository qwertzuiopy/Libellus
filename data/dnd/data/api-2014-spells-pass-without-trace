{id:"api-2014-spells-pass-without-trace",name:"Pass Without Trace",content:[{id:"Title",content:"Pass Without Trace"},{id:"StatGrid",content:[{title:"Level",content:"2"},{title:"Casting Time",content:"1 action"},{title:"Range",content:"Self"},{title:"Components",content:"V, S, M"},{title:"Duration",content:"Up to 1 hour"},{title:"School",content:"Abjuration"}]},{id:"Subtitle",content:"Effect"},{id:"MultiText",content:["A veil of shadows and silence radiates from you, masking you and your companions from detection. For the duration, each creature you choose within 30 feet of you (including you) has a +10 bonus to Dexterity (Stealth) checks and can't be tracked except by magical means. A creature that receives this bonus leaves behind no tracks or other traces of its passage."]}]}