{id:"api-2014-spells-heat-metal",name:"Heat Metal",content:[{id:"Title",content:"Heat Metal"},{id:"StatGrid",content:[{title:"Level",content:"2"},{title:"Casting Time",content:"1 action"},{title:"Range",content:"60 feet"},{title:"Components",content:"V, S, M"},{title:"Duration",content:"Up to 1 minute"},{title:"School",content:"Transmutation"},{title:"Save",content:"CON Save"},{title:"Damage",content:"Fire"}]},{id:"Subtitle",content:"Effect"},{id:"MultiText",content:["Choose a manufactured metal object, such as a metal weapon or a suit of heavy or medium metal armor, that you can see within range. You cause the object to glow red-hot. Any creature in physical contact with the object takes 2d8 fire damage when you cast the spell. Until the spell ends, you can use a bonus action on each of your subsequent turns to cause this damage again.","If a creature is holding or wearing the object and takes the damage from it, the creature must succeed on a constitution saving throw or drop the object if it can. If it doesn't drop the object, it has disadvantage on attack rolls and ability checks until the start of your next turn."]},{id:"Subtitle",content:"At higher levels"},{id:"MultiText",content:["When you cast this spell using a spell slot of 3rd level or higher, the damage increases by 1d8 for each slot level above 2nd."]},{id:"Table",content:[["slot level","2","3","4","5","6","7","8","9"],["damage","2d8","3d8","4d8","5d8","6d8","7d8","8d8","9d8"]]}]}