{id:"api-2014-spells-burning-hands",name:"Burning Hands",content:[{id:"Title",content:"Burning Hands"},{id:"StatGrid",content:[{title:"Level",content:"1"},{title:"Casting Time",content:"1 action"},{title:"Range",content:"Self (15ft cone)"},{title:"Components",content:"V, S"},{title:"Duration",content:"Instantaneous"},{title:"School",content:"Evocation"},{title:"Save",content:"DEX Save"},{title:"Damage",content:"Fire"}]},{id:"Subtitle",content:"Effect"},{id:"MultiText",content:["As you hold your hands with thumbs touching and fingers spread, a thin sheet of flames shoots forth from your outstretched fingertips. Each creature in a 15-foot cone must make a dexterity saving throw. A creature takes 3d6 fire damage on a failed save, or half as much damage on a successful one.","The fire ignites any flammable objects in the area that aren't being worn or carried."]},{id:"Subtitle",content:"At higher levels"},{id:"MultiText",content:["When you cast this spell using a spell slot of 2nd level or higher, the damage increases by 1d6 for each slot level above 1st."]},{id:"Table",content:[["slot level","1","2","3","4","5","6","7","8","9"],["damage","3d6","4d6","5d6","6d6","7d6","8d6","9d6","10d6","11d6"]]}]}