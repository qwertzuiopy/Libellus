{id:"api-2014-features-druidic",name:"Druidic",content:[{id:"Title",content:"Druidic"},{id:"StatGrid",content:[{title:"Level",content:"1"}]},{id:"MultiText",content:["You know Druidic, the secret language of druids. You can speak the language and use it to leave hidden messages. You and others who know this language automatically spot such a message. Others spot the message's presence with a successful DC 15 Wisdom (Perception) check but can't decipher it without magic."]},{id:"LinkList",content:[{id:"@api-2014-classes-druid",content:""}]}]}