{id:"spell-disintegrate",name:"Disintegrate",content:[{id:"Title",content:"Disintegrate"},{id:"StatGrid",content:[{title:"Level",content:"6"},{title:"Casting Time",content:"1 action"},{title:"Range",content:"60 feet (10ft cube)"},{title:"Components",content:"V, S, M"},{title:"Duration",content:"Instantaneous"},{title:"School",content:"Transmutation"},{title:"Save",content:"DEX Save"},{title:"Damage",content:"Force"}]},{id:"Subtitle",content:"Effect"},{id:"MultiText",content:["A thin green ray springs from your pointing finger to a target that you can see within range. The target can be a creature, an object, or a creation of magical force, such as the wall created by wall of force.","A creature targeted by this spell must make a dexterity saving throw. On a failed save, the target takes 10d6 + 40 force damage. If this damage reduces the target to 0 hit points, it is disintegrated.","A disintegrated creature and everything it is wearing and carrying, except magic items, are reduced to a pile of fine gray dust. The creature can be restored to life only by means of a true resurrection or a wish spell.","This spell automatically disintegrates a Large or smaller nonmagical object or a creation of magical force. If the target is a Huge or larger object or creation of force, this spell disintegrates a 10-foot-cube portion of it. A magic item is unaffected by this spell."]},{id:"Subtitle",content:"At higher levels"},{id:"MultiText",content:["When you cast this spell using a spell slot of 7th level or higher, the damage increases by 3d6 for each slot level above 6th."]},{id:"Table",content:[["slot level","6"],["damage","10d6 + 40"]]}]}