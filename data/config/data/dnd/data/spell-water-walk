{id:"spell-water-walk",name:"Water Walk",content:[{id:"Title",content:"Water Walk"},{id:"StatGrid",content:[{title:"Level",content:"3"},{title:"Casting Time",content:"1 action"},{title:"Range",content:"30 feet"},{title:"Components",content:"V, S, M"},{title:"Duration",content:"1 hour"},{title:"School",content:"Transmutation"}]},{id:"Subtitle",content:"Effect"},{id:"MultiText",content:["This spell grants the ability to move across any liquid surface--such as water, acid, mud, snow, quicksand, or lava--as if it were harmless solid ground (creatures crossing molten lava can still take damage from the heat). Up to ten willing creatures you can see within range gain this ability for the duration.","If you target a creature submerged in a liquid, the spell carries the target to the surface of the liquid at a rate of 60 feet per round."]}]}