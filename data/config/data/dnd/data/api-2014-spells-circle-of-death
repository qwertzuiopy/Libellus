{id:"api-2014-spells-circle-of-death",name:"Circle of Death",content:[{id:"Title",content:"Circle of Death"},{id:"StatGrid",content:[{title:"Level",content:"6"},{title:"Casting Time",content:"1 action"},{title:"Range",content:"150 feet (60ft sphere)"},{title:"Components",content:"V, S, M"},{title:"Duration",content:"Instantaneous"},{title:"School",content:"Necromancy"},{title:"Save",content:"CON Save"},{title:"Damage",content:"Necrotic"}]},{id:"Subtitle",content:"Effect"},{id:"MultiText",content:["A sphere of negative energy ripples out in a 60-foot radius sphere from a point within range. Each creature in that area must make a constitution saving throw. A target takes 8d6 necrotic damage on a failed save, or half as much damage on a successful one."]},{id:"Subtitle",content:"At higher levels"},{id:"MultiText",content:["When you cast this spell using a spell slot of 7th level or higher, the damage increases by 2d6 for each slot level above 6th."]},{id:"Table",content:[["slot level","6","7","8","9"],["damage","8d6","10d6","12d6","14d6"]]}]}