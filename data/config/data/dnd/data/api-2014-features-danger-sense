{id:"api-2014-features-danger-sense",name:"Danger Sense",content:[{id:"Title",content:"Danger Sense"},{id:"StatGrid",content:[{title:"Level",content:"2"}]},{id:"MultiText",content:["At 2nd level, you gain an uncanny sense of when things nearby aren't as they should be, giving you an edge when you dodge away from danger. You have advantage on Dexterity saving throws against effects that you can see, such as traps and spells. To gain this benefit, you can't be blinded, deafened, or incapacitated."]},{id:"LinkList",content:[{id:"@api-2014-classes-barbarian",content:""}]}]}