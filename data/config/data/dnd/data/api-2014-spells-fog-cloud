{id:"api-2014-spells-fog-cloud",name:"Fog Cloud",content:[{id:"Title",content:"Fog Cloud"},{id:"StatGrid",content:[{title:"Level",content:"1"},{title:"Casting Time",content:"1 action"},{title:"Range",content:"120 feet (20ft sphere)"},{title:"Components",content:"V, S"},{title:"Duration",content:"Up to 1 hour"},{title:"School",content:"Conjuration"}]},{id:"Subtitle",content:"Effect"},{id:"MultiText",content:["You create a 20-foot-radius sphere of fog centered on a point within range. The sphere spreads around corners, and its area is heavily obscured. It lasts for the duration or until a wind of moderate or greater speed (at least 10 miles per hour) disperses it."]},{id:"Subtitle",content:"At higher levels"},{id:"MultiText",content:["When you cast this spell using a spell slot of 2nd level or higher, the radius of the fog increases by 20 feet for each slot level above 1st."]}]}