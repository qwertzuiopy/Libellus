{id:"api-2014-spells-greater-restoration",name:"Greater Restoration",content:[{id:"Title",content:"Greater Restoration"},{id:"StatGrid",content:[{title:"Level",content:"5"},{title:"Casting Time",content:"1 action"},{title:"Range",content:"Touch"},{title:"Components",content:"V, S, M"},{title:"Duration",content:"Instantaneous"},{title:"School",content:"Abjuration"}]},{id:"Subtitle",content:"Effect"},{id:"MultiText",content:["You imbue a creature you touch with positive energy to undo a debilitating effect. You can reduce the target's exhaustion level by one, or end one of the following effects on the target:","- One effect that charmed or petrified the target","- One curse, including the target's attunement to a cursed magic item","- Any reduction to one of the target's ability scores","- One effect reducing the target's hit point maximum"]}]}