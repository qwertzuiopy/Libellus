{id:"api-2014-spells-transport-via-plants",name:"Transport via Plants",content:[{id:"Title",content:"Transport via Plants"},{id:"StatGrid",content:[{title:"Level",content:"6"},{title:"Casting Time",content:"1 action"},{title:"Range",content:"10 feet"},{title:"Components",content:"V, S"},{title:"Duration",content:"1 round"},{title:"School",content:"Conjuration"}]},{id:"Subtitle",content:"Effect"},{id:"MultiText",content:["This spell creates a magical link between a Large or larger inanimate plant within range and another plant, at any distance, on the same plane of existence. You must have seen or touched the destination plant at least once before. For the duration, any creature can step into the target plant and exit from the destination plant by using 5 feet of movement."]}]}