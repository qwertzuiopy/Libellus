{id:"spell-flame-strike",name:"Flame Strike",content:[{id:"Title",content:"Flame Strike"},{id:"StatGrid",content:[{title:"Level",content:"5"},{title:"Casting Time",content:"1 action"},{title:"Range",content:"60 feet (40ft cylinder)"},{title:"Components",content:"V, S, M"},{title:"Duration",content:"Instantaneous"},{title:"School",content:"Evocation"},{title:"Save",content:"DEX Save"},{title:"Damage",content:"Fire"}]},{id:"Subtitle",content:"Effect"},{id:"MultiText",content:["A vertical column of divine fire roars down from the heavens in a location you specify. Each creature in a 10-foot-radius, 40-foot-high cylinder centered on a point within range must make a dexterity saving throw. A creature takes 4d6 fire damage and 4d6 radiant damage on a failed save, or half as much damage on a successful one."]},{id:"Subtitle",content:"At higher levels"},{id:"MultiText",content:["When you cast this spell using a spell slot of 6th level or higher, the fire damage or the radiant damage (your choice) increases by 1d6 for each slot level above 5th."]},{id:"Table",content:[["slot level","5","6","7","8","9"],["damage","4d6 + 4d6","4d6 + 5d6","4d6 + 6d6","4d6 + 7d6","4d6 + 8d6"]]}]}