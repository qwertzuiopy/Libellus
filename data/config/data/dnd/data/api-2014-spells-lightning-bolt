{id:"api-2014-spells-lightning-bolt",name:"Lightning Bolt",content:[{id:"Title",content:"Lightning Bolt"},{id:"StatGrid",content:[{title:"Level",content:"3"},{title:"Casting Time",content:"1 action"},{title:"Range",content:"Self (100ft line)"},{title:"Components",content:"V, S, M"},{title:"Duration",content:"Instantaneous"},{title:"School",content:"Evocation"},{title:"Save",content:"DEX Save"},{title:"Damage",content:"Lightning"}]},{id:"Subtitle",content:"Effect"},{id:"MultiText",content:["A stroke of lightning forming a line 100 feet long and 5 feet wide blasts out from you in a direction you choose. Each creature in the line must make a dexterity saving throw. A creature takes 8d6 lightning damage on a failed save, or half as much damage on a successful one.","The lightning ignites flammable objects in the area that aren't being worn or carried."]},{id:"Subtitle",content:"At higher levels"},{id:"MultiText",content:["When you cast this spell using a spell slot of 4th level or higher, the damage increases by 1d6 for each slot level above 3rd."]},{id:"Table",content:[["slot level","3","4","5","6","7","8","9"],["damage","8d6","9d6","10d6","11d6","12d6","13d6","14d6"]]}]}