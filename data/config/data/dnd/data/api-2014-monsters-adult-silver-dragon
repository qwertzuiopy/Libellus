{id:"api-2014-monsters-adult-silver-dragon",name:"Adult Silver Dragon",category:"monster",content:[{id:"Title",content:"Adult Silver Dragon"},{id:"Image",url:"https://www.dnd5eapi.co/api/images/monsters/adult-silver-dragon.png"},{id:"StatGrid",content:[{title:"Strength",content:"27 / +8"},{title:"Dexterity",content:"10 / 0"},{title:"Constitution",content:"25 / +7"},{title:"Intelligence",content:"16 / +3"},{title:"Wisdom",content:"13 / +1"},{title:"Charisma",content:"21 / +5"},{title:"Alignment",content:"lawful good"},{title:"Armor Class",content:"19"},{title:"Hit Dice",content:"18d12"},{title:"Type",content:"dragon"},{title:"Challenge Rating",content:"16"},{title:"Size",content:"Huge"},{title:"Hit Points",content:"243 / 18d12+126"}]},{id:"StatList",content:[{title:"Speed",content:["40 ft. walk","80 ft. fly"]},{title:"Languages",content:["Common"," Draconic"]},{title:"Senses",content:["blindsight 60 ft.","darkvision120 ft."]},{title:"Saving Throws",content:["+5 dex","+12 con","+6 wis","+10 cha"]},{title:"Skills",content:["+8 arcana","+8 history","+11 perception","+5 stealth"]}]},{id:"Subtitle",content:"Abilities"},{id:"TitledText",content:[{title:"Legendary Resistance",content:"If the dragon fails a saving throw, it can choose to succeed instead."}]},{id:"Subtitle",content:"Actions"},{id:"TitledText",content:[{title:"Multiattack",content:"The dragon can use its Frightful Presence. It then makes three attacks: one with its bite and two with its claws."},{title:"Bite",content:"Melee Weapon Attack: +13 to hit, reach 10 ft., one target. Hit: 19 (2d10 + 8) piercing damage."},{title:"Claw",content:"Melee Weapon Attack: +13 to hit, reach 5 ft., one target. Hit: 15 (2d6 + 8) slashing damage."},{title:"Tail",content:"Melee Weapon Attack: +13 to hit, reach 15 ft., one target. Hit: 17 (2d8 + 8) bludgeoning damage."},{title:"Frightful Presence",content:"Each creature of the dragon's choice that is within 120 feet of the dragon and aware of it must succeed on a DC 18 Wisdom saving throw or become frightened for 1 minute. A creature can repeat the saving throw at the end of each of its turns, ending the effect on itself on a success. If a creature's saving throw is successful or the effect ends for it, the creature is immune to the dragon's Frightful Presence for the next 24 hours."},{title:"Breath Weapons",content:"The dragon uses one of the following breath weapons.
Cold Breath. The dragon exhales an icy blast in a 60-foot cone. Each creature in that area must make a DC 20 Constitution saving throw, taking 58 (13d8) cold damage on a failed save, or half as much damage on a successful one.
Paralyzing Breath. The dragon exhales paralyzing gas in a 60-foot cone. Each creature in that area must succeed on a DC 20 Constitution saving throw or be paralyzed for 1 minute. A creature can repeat the saving throw at the end of each of its turns, ending the effect on itself on a success."}]},{id:"Subtitle",content:"Legendary Actions"},{id:"TitledText",content:[{title:"Detect",content:"The dragon makes a Wisdom (Perception) check."},{title:"Tail Attack",content:"The dragon makes a tail attack."},{title:"Wing Attack (Costs 2 Actions)",content:"The dragon beats its wings. Each creature within 10 ft. of the dragon must succeed on a DC 22 Dexterity saving throw or take 15 (2d6 + 8) bludgeoning damage and be knocked prone. The dragon can then fly up to half its flying speed."}]}]}