{id:"monster-ancient-gold-dragon",name:"Ancient Gold Dragon",category:"monster",content:[{id:"Title",content:"Ancient Gold Dragon"},{id:"Image",url:"https://www.dnd5eapi.co/api/images/monsters/ancient-gold-dragon.png"},{id:"StatGrid",content:[{title:"Strength",content:"30 / +10"},{title:"Dexterity",content:"14 / +2"},{title:"Constitution",content:"29 / +9"},{title:"Intelligence",content:"18 / +4"},{title:"Wisdom",content:"17 / +3"},{title:"Charisma",content:"28 / +9"},{title:"Alignment",content:"lawful good"},{title:"Armor Class",content:"22"},{title:"Hit Dice",content:"28d20"},{title:"Type",content:"dragon"},{title:"Challenge Rating",content:"24"},{title:"Size",content:"Gargantuan"},{title:"Hit Points",content:"546 / 28d20+252"}]},{id:"StatList",content:[{title:"Speed",content:["40 ft. walk","40 ft. swim","80 ft. fly"]},{title:"Languages",content:["Common"," Draconic"]},{title:"Senses",content:["blindsight 60 ft.","darkvision120 ft."]},{title:"Saving Throws",content:["+9 dex","+16 con","+10 wis","+16 cha"]},{title:"Skills",content:["+10 insight","+17 perception","+16 persuasion","+9 stealth"]}]},{id:"Subtitle",content:"Abilities"},{id:"TitledText",content:[{title:"Amphibious",content:"The dragon can breathe air and water."},{title:"Legendary Resistance",content:"If the dragon fails a saving throw, it can choose to succeed instead."}]},{id:"Subtitle",content:"Actions"},{id:"TitledText",content:[{title:"Multiattack",content:"The dragon can use its Frightful Presence. It then makes three attacks: one with its bite and two with its claws."},{title:"Bite",content:"Melee Weapon Attack: +17 to hit, reach 15 ft., one target. Hit: 21 (2d10 + 10) piercing damage."},{title:"Claw",content:"Melee Weapon Attack: +17 to hit, reach 10 ft., one target. Hit: 17 (2d6 + 10) slashing damage."},{title:"Tail",content:"Melee Weapon Attack: +17 to hit, reach 20 ft., one target. Hit: 19 (2d8 + 10) bludgeoning damage."},{title:"Frightful Presence",content:"Each creature of the dragon's choice that is within 120 feet of the dragon and aware of it must succeed on a DC 24 Wisdom saving throw or become frightened for 1 minute. A creature can repeat the saving throw at the end of each of its turns, ending the effect on itself on a success. If a creature's saving throw is successful or the effect ends for it, the creature is immune to the dragon's Frightful Presence for the next 24 hours."},{title:"Breath Weapons",content:"The dragon uses one of the following breath weapons.
Fire Breath. The dragon exhales fire in a 90-foot cone. Each creature in that area must make a DC 24 Dexterity saving throw, taking 71 (13d10) fire damage on a failed save, or half as much damage on a successful one.
Weakening Breath. The dragon exhales gas in a 90-foot cone. Each creature in that area must succeed on a DC 24 Strength saving throw or have disadvantage on Strength-based attack rolls, Strength checks, and Strength saving throws for 1 minute. A creature can repeat the saving throw at the end of each of its turns, ending the effect on itself on a success."},{title:"Change Shape",content:"The dragon magically polymorphs into a humanoid or beast that has a challenge rating no higher than its own, or back into its true form. It reverts to its true form if it dies. Any equipment it is wearing or carrying is absorbed or borne by the new form (the dragon's choice).
In a new form, the dragon retains its alignment, hit points, Hit Dice, ability to speak, proficiencies, Legendary Resistance, lair actions, and Intelligence, Wisdom, and Charisma scores, as well as this action. Its statistics and capabilities are otherwise replaced by those of the new form, except any class features or legendary actions of that form."}]},{id:"Subtitle",content:"Legendary Actions"},{id:"TitledText",content:[{title:"Detect",content:"The dragon makes a Wisdom (Perception) check."},{title:"Tail Attack",content:"The dragon makes a tail attack."},{title:"Wing Attack (Costs 2 Actions)",content:"The dragon beats its wings. Each creature within 15 ft. of the dragon must succeed on a DC 25 Dexterity saving throw or take 17 (2d6 + 10) bludgeoning damage and be knocked prone. The dragon can then fly up to half its flying speed."}]}]}