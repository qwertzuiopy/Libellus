{id:"spell-protection-from-poison",name:"Protection from Poison",content:[{id:"Title",content:"Protection from Poison"},{id:"StatGrid",content:[{title:"Level",content:"2"},{title:"Casting Time",content:"1 action"},{title:"Range",content:"Touch"},{title:"Components",content:"V, S"},{title:"Duration",content:"1 hour"},{title:"School",content:"Abjuration"}]},{id:"Subtitle",content:"Effect"},{id:"MultiText",content:["You touch a creature. If it is poisoned, you neutralize the poison. If more than one poison afflicts the target, you neutralize one poison that you know is present, or you neutralize one at random.","For the duration, the target has advantage on saving throws against being poisoned, and it has resistance to poison damage."]}]}