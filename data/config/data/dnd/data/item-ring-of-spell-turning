{id:"item-ring-of-spell-turning",name:"Ring of Spell Turning",content:[{id:"Title",content:"Ring of Spell Turning"},{id:"StatGrid",content:[{title:"Category",content:"Ring"},{title:"Rarity",content:"Legendary"}]},{id:"MultiText",content:["Ring, legendary (requires attunement)","While wearing this ring, you have advantage on saving throws against any spell that targets only you (not in an area of effect). In addition, if you roll a 20 for the save and the spell is 7th level or lower, the spell has no effect on you and instead targets the caster, using the slot level, spell save DC, attack bonus, and spellcasting ability of the caster."]}]}