{id:"spell-blindness-deafness",name:"Blindness/Deafness",content:[{id:"Title",content:"Blindness/Deafness"},{id:"StatGrid",content:[{title:"Level",content:"2"},{title:"Casting Time",content:"1 action"},{title:"Range",content:"30 feet"},{title:"Components",content:"V"},{title:"Duration",content:"1 minute"},{title:"School",content:"Necromancy"},{title:"Save",content:"CON Save"}]},{id:"Subtitle",content:"Effect"},{id:"MultiText",content:["You can blind or deafen a foe. Choose one creature that you can see within range to make a constitution saving throw. If it fails, the target is either blinded or deafened (your choice) for the duration. At the end of each of its turns, the target can make a constitution saving throw. On a success, the spell ends."]},{id:"Subtitle",content:"At higher levels"},{id:"MultiText",content:["When you cast this spell using a spell slot of 3rd level or higher, you can target one additional creature for each slot level above 2nd."]}]}