{id:"spell-speak-with-animals",name:"Speak with Animals",content:[{id:"Title",content:"Speak with Animals"},{id:"StatGrid",content:[{title:"Level",content:"1"},{title:"Casting Time",content:"1 action"},{title:"Range",content:"Self"},{title:"Components",content:"V, S"},{title:"Duration",content:"10 minutes"},{title:"School",content:"Divination"}]},{id:"Subtitle",content:"Effect"},{id:"MultiText",content:["You gain the ability to comprehend and verbally communicate with beasts for the duration. The knowledge and awareness of many beasts is limited by their intelligence, but at a minimum, beasts can give you information about nearby locations and monsters, including whatever they can perceive or have perceived within the past day. You might be able to persuade a beast to perform a small favor for you, at the GM's discretion."]}]}