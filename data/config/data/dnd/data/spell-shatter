{id:"spell-shatter",name:"Shatter",content:[{id:"Title",content:"Shatter"},{id:"StatGrid",content:[{title:"Level",content:"2"},{title:"Casting Time",content:"1 action"},{title:"Range",content:"60 feet (10ft sphere)"},{title:"Components",content:"V, S, M"},{title:"Duration",content:"Instantaneous"},{title:"School",content:"Evocation"},{title:"Save",content:"CON Save"},{title:"Damage",content:"Thunder"}]},{id:"Subtitle",content:"Effect"},{id:"MultiText",content:["A sudden loud ringing noise, painfully intense, erupts from a point of your choice within range. Each creature in a 10-foot-radius sphere centered on that point must make a Constitution saving throw. A creature takes 3d8 thunder damage on a failed save, or half as much damage on a successful one. A creature made of inorganic material such as stone, crystal, or metal has disadvantage on this saving throw.","A non-magical item that is not worn or carried also suffers damage if it is in the area of the spell."]},{id:"Subtitle",content:"At higher levels"},{id:"MultiText",content:["When you cast this spell using a 3 or higher level spell slot, the damage of the spell increases by 1d8 for each level of higher spell slot 2."]},{id:"Table",content:[["slot level","2","3","4","5","6","7","8","9"],["damage","3d8","4d8","5d8","6d8","7d8","8d8","9d8","10d8"]]}]}