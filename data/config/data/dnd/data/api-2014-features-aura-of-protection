{id:"api-2014-features-aura-of-protection",name:"Aura of Protection",content:[{id:"Title",content:"Aura of Protection"},{id:"StatGrid",content:[{title:"Level",content:"6"}]},{id:"MultiText",content:["Starting at 6th level, whenever you or a friendly creature within 10 feet of you must make a saving throw, the creature gains a bonus to the saving throw equal to your Charisma modifier (with a minimum bonus of +1). You must be conscious to grant this bonus.","At 18th level, the range of this aura increases to 30 feet."]},{id:"LinkList",content:[{id:"@api-2014-classes-paladin",content:""}]}]}