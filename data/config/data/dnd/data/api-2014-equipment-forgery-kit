{id:"api-2014-equipment-forgery-kit",name:"Forgery Kit",content:[{id:"Title",content:"Forgery Kit"},{id:"StatGrid",content:[{title:"Category",content:"Adventuring Gear"},{title:"Cost",content:"15gp"},{title:"Weight",content:"5lb"},{title:"Type",content:"Kits"}]},{id:"MultiText",content:["This small box contains a variety of papers and parchments, pens and inks, seals and sealing wax, gold and silver leaf, and other supplies necessary to create convincing forgeries of physical documents. Proficiency with this kit lets you add your proficiency bonus to any ability checks you make to create a physical forgery of a document."]}]}