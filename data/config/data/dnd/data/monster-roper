{id:"monster-roper",name:"Roper",category:"monster",content:[{id:"Title",content:"Roper"},{id:"Image",url:"https://www.dnd5eapi.co/api/images/monsters/roper.png"},{id:"StatGrid",content:[{title:"Strength",content:"18 / +4"},{title:"Dexterity",content:"8 / -1"},{title:"Constitution",content:"17 / +3"},{title:"Intelligence",content:"7 / -2"},{title:"Wisdom",content:"16 / +3"},{title:"Charisma",content:"6 / -2"},{title:"Alignment",content:"neutral evil"},{title:"Armor Class",content:"20"},{title:"Hit Dice",content:"11d10"},{title:"Type",content:"monstrosity"},{title:"Challenge Rating",content:"5"},{title:"Size",content:"Large"},{title:"Hit Points",content:"93 / 11d10+33"}]},{id:"StatList",content:[{title:"Speed",content:["10 ft. walk","10 ft. climb"]},{title:"Languages",content:[""]},{title:"Senses",content:["darkvision60 ft."]},{title:"Saving Throws",content:[]},{title:"Skills",content:["+6 perception","+5 stealth"]}]},{id:"Subtitle",content:"Abilities"},{id:"TitledText",content:[{title:"False Appearance",content:"While the roper remains motionless, it is indistinguishable from a normal cave formation, such as a stalagmite."},{title:"Grasping Tendrils",content:"The roper can have up to six tendrils at a time. Each tendril can be attacked (AC 20; 10 hit points; immunity to poison and psychic damage). Destroying a tendril deals no damage to the roper, which can extrude a replacement tendril on its next turn. A tendril can also be broken if a creature takes an action and succeeds on a DC 15 Strength check against it."},{title:"Spider Climb",content:"The roper can climb difficult surfaces, including upside down on ceilings, without needing to make an ability check."}]},{id:"Subtitle",content:"Actions"},{id:"TitledText",content:[{title:"Multiattack",content:"The roper makes four attacks with its tendrils, uses Reel, and makes one attack with its bite."},{title:"Bite",content:"Melee Weapon Attack: +7 to hit, reach 5 ft., one target. Hit: 22 (4d8 + 4) piercing damage."},{title:"Tendril",content:"Melee Weapon Attack: +7 to hit, reach 50 ft., one creature. Hit: The target is grappled (escape DC 15). Until the grapple ends, the target is restrained and has disadvantage on Strength checks and Strength saving throws, and the roper can't use the same tendril on another target."},{title:"Reel",content:"The roper pulls each creature grappled by it up to 25 ft. straight toward it."}]}]}