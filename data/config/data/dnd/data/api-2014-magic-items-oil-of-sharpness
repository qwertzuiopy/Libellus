{id:"api-2014-magic-items-oil-of-sharpness",name:"Oil of Sharpness",content:[{id:"Title",content:"Oil of Sharpness"},{id:"StatGrid",content:[{title:"Category",content:"Potion"},{title:"Rarity",content:"Very Rare"}]},{id:"MultiText",content:["Potion, very rare","This clear, gelatinous oil sparkles with tiny, ultrathin silver shards. The oil can coat one slashing or piercing weapon or up to 5 pieces of slashing or piercing ammunition. Applying the oil takes 1 minute. For 1 hour, the coated item is magical and has a +3 bonus to attack and damage rolls."]}]}