{id:"spell-chain-lightning",name:"Chain Lightning",content:[{id:"Title",content:"Chain Lightning"},{id:"StatGrid",content:[{title:"Level",content:"6"},{title:"Casting Time",content:"1 action"},{title:"Range",content:"150 feet"},{title:"Components",content:"V, S, M"},{title:"Duration",content:"Instantaneous"},{title:"School",content:"Evocation"},{title:"Save",content:"DEX Save"},{title:"Damage",content:"Lightning"}]},{id:"Subtitle",content:"Effect"},{id:"MultiText",content:["You create a bolt of lightning that arcs toward a target of your choice that you can see within range. Three bolts then leap from that target to as many as three other targets, each of which must be within 30 feet of the first target. A target can be a creature or an object and can be targeted by only one of the bolts.","A target must make a dexterity saving throw. The target takes 10d8 lightning damage on a failed save, or half as much damage on a successful one."]},{id:"Subtitle",content:"At higher levels"},{id:"MultiText",content:["When you cast this spell using a spell slot of 7th level or higher, one additional bolt leaps from the first target to another target for each slot level above 6th."]},{id:"Table",content:[["slot level","6"],["damage","10d8"]]}]}