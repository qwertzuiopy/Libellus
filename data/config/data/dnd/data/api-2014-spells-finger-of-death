{id:"api-2014-spells-finger-of-death",name:"Finger of Death",content:[{id:"Title",content:"Finger of Death"},{id:"StatGrid",content:[{title:"Level",content:"7"},{title:"Casting Time",content:"1 action"},{title:"Range",content:"60 feet"},{title:"Components",content:"V, S"},{title:"Duration",content:"Instantaneous"},{title:"School",content:"Necromancy"},{title:"Save",content:"CON Save"},{title:"Damage",content:"Necrotic"}]},{id:"Subtitle",content:"Effect"},{id:"MultiText",content:["You send negative energy coursing through a creature that you can see within range, causing it searing pain. The target must make a constitution saving throw. It takes 7d8 + 30 necrotic damage on a failed save, or half as much damage on a successful one.","A humanoid killed by this spell rises at the start of your next turn as a zombie that is permanently under your command, following your verbal orders to the best of its ability."]},{id:"Table",content:[["slot level","7"],["damage","7d8 + 30"]]}]}