{id:"spell-creation",name:"Creation",content:[{id:"Title",content:"Creation"},{id:"StatGrid",content:[{title:"Level",content:"5"},{title:"Casting Time",content:"1 minute"},{title:"Range",content:"30 feet (5ft cube)"},{title:"Components",content:"V, S, M"},{title:"Duration",content:"Special"},{title:"School",content:"Illusion"}]},{id:"Subtitle",content:"Effect"},{id:"MultiText",content:["You pull wisps of shadow material from the Shadowfell to create a nonliving object of vegetable matter within range: soft goods, rope, wood, or something similar. You can also use this spell to create mineral objects such as stone, crystal, or metal. The object created must be no larger than a 5-foot cube, and the object must be of a form and material that you have seen before.","The duration depends on the object's material. If the object is composed of multiple materials, use the shortest duration.","| Material | Duration |","|---|---|","| Vegetable matter | 1 day |","| Stone or crystal | 12 hours |","| Precious metals | 1 hour |","| Gems | 10 minutes |","| Adamantine or mithral | 1 minute |","Using any material created by this spell as another spell's material component causes that spell to fail."]},{id:"Subtitle",content:"At higher levels"},{id:"MultiText",content:["When you cast this spell using a spell slot of 6th level or higher, the cube increases by 5 feet for each slot level above 5th."]}]}