{id:"item-dice-set",name:"Dice Set",content:[{id:"Title",content:"Dice Set"},{id:"StatGrid",content:[{title:"Category",content:"Tools"},{title:"Cost",content:"1sp"},{title:"Type",content:"Gaming Sets"}]},{id:"MultiText",content:["This item encompasses a wide range of game pieces, including dice and decks of cards (for games such as Three-Dragon Ante). A few common examples appear on the Tools table, but other kinds of gaming sets exist. If you are proficient with a gaming set, you can add your proficiency bonus to ability checks you make to play a game with that set. Each type of gaming set requires a separate proficiency."]}]}