{id:"spell-fire-bolt",name:"Fire Bolt",content:[{id:"Title",content:"Fire Bolt"},{id:"StatGrid",content:[{title:"Level",content:"0"},{title:"Casting Time",content:"1 action"},{title:"Range",content:"120 feet"},{title:"Components",content:"V, S"},{title:"Duration",content:"Instantaneous"},{title:"School",content:"Evocation"},{title:"Attack",content:"ranged"},{title:"Damage",content:"Fire"}]},{id:"Subtitle",content:"Effect"},{id:"MultiText",content:["You hurl a mote of fire at a creature or object within range. Make a ranged spell attack against the target. On a hit, the target takes 1d10 fire damage. A flammable object hit by this spell ignites if it isn't being worn or carried.","This spell's damage increases by 1d10 when you reach 5th level (2d10), 11th level (3d10), and 17th level (4d10)."]},{id:"Table",content:[["character level","1","5","11","17"],["damage","1d10","2d10","3d10","4d10"]]}]}