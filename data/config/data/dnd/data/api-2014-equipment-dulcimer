{id:"api-2014-equipment-dulcimer",name:"Dulcimer",content:[{id:"Title",content:"Dulcimer"},{id:"Image",url:"https://www.dnd5eapi.co/api/images/equipment/dulcimer.png"},{id:"StatGrid",content:[{title:"Category",content:"Tools"},{title:"Cost",content:"25gp"},{title:"Weight",content:"10lb"},{title:"Type",content:"Musical Instrument"}]},{id:"MultiText",content:["Several of the most common types of musical instruments are shown on the table as examples. If you have proficiency with a given musical instrument, you can add your proficiency bonus to any ability checks you make to play music with the instrument. A bard can use a musical instrument as a spellcasting focus. Each type of musical instrument requires a separate proficiency."]}]}