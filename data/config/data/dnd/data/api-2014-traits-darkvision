{id:"api-2014-traits-darkvision",name:"Darkvision",content:[{id:"Title",content:"Darkvision"},{id:"MultiText",content:["You have superior vision in dark and dim conditions. You can see in dim light within 60 feet of you as if it were bright light, and in darkness as if it were dim light. You cannot discern color in darkness, only shades of gray."]}]}