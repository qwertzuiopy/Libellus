{id:"api-2014-spells-ray-of-frost",name:"Ray of Frost",content:[{id:"Title",content:"Ray of Frost"},{id:"StatGrid",content:[{title:"Level",content:"0"},{title:"Casting Time",content:"1 action"},{title:"Range",content:"60 feet"},{title:"Components",content:"V, S"},{title:"Duration",content:"Instantaneous"},{title:"School",content:"Evocation"},{title:"Attack",content:"ranged"},{title:"Damage",content:"Cold"}]},{id:"Subtitle",content:"Effect"},{id:"MultiText",content:["A frigid beam of blue-white light streaks toward a creature within range. Make a ranged spell attack against the target. On a hit, it takes 1d8 cold damage, and its speed is reduced by 10 feet until the start of your next turn.","The spell's damage increases by 1d8 when you reach 5th level (2d8), 11th level (3d8), and 17th level (4d8)."]},{id:"Table",content:[["character level","1","5","11","17"],["damage","1d8","2d8","3d8","4d8"]]}]}