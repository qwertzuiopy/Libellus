{id:"spell-counterspell",name:"Counterspell",content:[{id:"Title",content:"Counterspell"},{id:"StatGrid",content:[{title:"Level",content:"3"},{title:"Casting Time",content:"1 reaction"},{title:"Range",content:"60 feet"},{title:"Components",content:"S"},{title:"Duration",content:"Instantaneous"},{title:"School",content:"Abjuration"}]},{id:"Subtitle",content:"Effect"},{id:"MultiText",content:["You attempt to interrupt a creature in the process of casting a spell. If the creature is casting a spell of 3rd level or lower, its spell fails and has no effect. If it is casting a spell of 4th level or higher, make an ability check using your spellcasting ability. The DC equals 10 + the spell's level. On a success, the creature's spell fails and has no effect."]},{id:"Subtitle",content:"At higher levels"},{id:"MultiText",content:["When you cast this spell using a spell slot of 4th level or higher, the interrupted spell has no effect if its level is less than or equal to the level of the spell slot you used."]}]}