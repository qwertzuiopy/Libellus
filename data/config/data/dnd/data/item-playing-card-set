{id:"item-playing-card-set",name:"Playing Card Set",content:[{id:"Title",content:"Playing Card Set"},{id:"Image",url:"https://www.dnd5eapi.co/api/images/equipment/playing-card-set.png"},{id:"StatGrid",content:[{title:"Category",content:"Tools"},{title:"Cost",content:"5sp"},{title:"Type",content:"Gaming Sets"}]},{id:"MultiText",content:["This item encompasses a wide range of game pieces, including dice and decks of cards (for games such as Three-Dragon Ante). A few common examples appear on the Tools table, but other kinds of gaming sets exist. If you are proficient with a gaming set, you can add your proficiency bonus to ability checks you make to play a game with that set. Each type of gaming set requires a separate proficiency."]}]}