{id:"api-2014-spells-ray-of-enfeeblement",name:"Ray of Enfeeblement",content:[{id:"Title",content:"Ray of Enfeeblement"},{id:"StatGrid",content:[{title:"Level",content:"2"},{title:"Casting Time",content:"1 action"},{title:"Range",content:"60 feet"},{title:"Components",content:"V, S"},{title:"Duration",content:"Up to 1 minute"},{title:"School",content:"Necromancy"},{title:"Attack",content:"ranged"}]},{id:"Subtitle",content:"Effect"},{id:"MultiText",content:["A black beam of enervating energy springs from your finger toward a creature within range. Make a ranged spell attack against the target. On a hit, the target deals only half damage with weapon attacks that use Strength until the spell ends.","At the end of each of the target's turns, it can make a constitution saving throw against the spell. On a success, the spell ends."]}]}