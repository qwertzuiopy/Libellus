{id:"api-2014-features-additional-magical-secrets",name:"Additional Magical Secrets",content:[{id:"Title",content:"Additional Magical Secrets"},{id:"StatGrid",content:[{title:"Level",content:"6"}]},{id:"MultiText",content:["At 6th level, you learn two spells of your choice from any class. A spell you choose must be of a level you can cast, as shown on the Bard table, or a cantrip. The chosen spells count as bard spells for you but don't count against the number of bard spells you know."]},{id:"LinkList",content:[{id:"@api-2014-classes-bard",content:""},{id:"@api-2014-subclasses-lore",content:""}]}]}