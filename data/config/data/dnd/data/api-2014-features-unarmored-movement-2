{id:"api-2014-features-unarmored-movement-2",name:"Unarmored Movement",content:[{id:"Title",content:"Unarmored Movement"},{id:"StatGrid",content:[{title:"Level",content:"9"}]},{id:"MultiText",content:["Starting at 2nd level, your speed increases by 10 feet while you are not wearing armor or wielding a shield. This bonus increases when you reach certain monk levels, as shown in Table: The Monk.","At 9th level, you gain the ability to move along vertical surfaces and across liquids on your turn without falling during the move."]},{id:"LinkList",content:[{id:"@api-2014-classes-monk",content:""}]}]}