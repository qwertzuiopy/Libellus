{id:"api-2014-spells-create-or-destroy-water",name:"Create or Destroy Water",content:[{id:"Title",content:"Create or Destroy Water"},{id:"StatGrid",content:[{title:"Level",content:"1"},{title:"Casting Time",content:"1 action"},{title:"Range",content:"30 feet (30ft cube)"},{title:"Components",content:"V, S, M"},{title:"Duration",content:"Instantaneous"},{title:"School",content:"Transmutation"}]},{id:"Subtitle",content:"Effect"},{id:"MultiText",content:["You either create or destroy water.","***Create Water.*** You create up to 10 gallons of clean water within range in an open container. Alternatively, the water falls as rain in a 30-foot cube within range.","***Destroy Water.*** You destroy up to 10 gallons of water in an open container within range. Alternatively, you destroy fog in a 30-foot cube within range."]},{id:"Subtitle",content:"At higher levels"},{id:"MultiText",content:["When you cast this spell using a spell slot of 2nd level or higher, you create or destroy 10 additional gallons of water, or the size of the cube increases by 5 feet, for each slot level above 1st."]}]}