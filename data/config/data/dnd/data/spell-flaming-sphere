{id:"spell-flaming-sphere",name:"Flaming Sphere",content:[{id:"Title",content:"Flaming Sphere"},{id:"StatGrid",content:[{title:"Level",content:"2"},{title:"Casting Time",content:"1 action"},{title:"Range",content:"60 feet"},{title:"Components",content:"V, S, M"},{title:"Duration",content:"Up to 1 minute"},{title:"School",content:"Conjuration"},{title:"Damage",content:"Fire"}]},{id:"Subtitle",content:"Effect"},{id:"MultiText",content:["A 5-foot-diameter sphere of fire appears in an unoccupied space of your choice within range and lasts for the duration. Any creature that ends its turn within 5 feet of the sphere must make a dexterity saving throw. The creature takes 2d6 fire damage on a failed save, or half as much damage on a successful one.","As a bonus action, you can move the sphere up to 30 feet. If you ram the sphere into a creature, that creature must make the saving throw against the sphere's damage, and the sphere stops moving this turn.","When you move the sphere, you can direct it over barriers up to 5 feet tall and jump it across pits up to 10 feet wide. The sphere ignites flammable objects not being worn or carried, and it sheds bright light in a 20-foot radius and dim light for an additional 20 feet."]},{id:"Subtitle",content:"At higher levels"},{id:"MultiText",content:["When you cast this spell using a spell slot of 3rd level or higher, the damage increases by 1d6 for each slot level above 2nd."]},{id:"Table",content:[["slot level","2","3","4","5","6","7","8","9"],["damage","2d6","3d6","4d6","5d6","6d6","7d6","8d6","9d6"]]}]}