{id:"api-2014-spells-eldritch-blast",name:"Eldritch Blast",content:[{id:"Title",content:"Eldritch Blast"},{id:"StatGrid",content:[{title:"Level",content:"0"},{title:"Casting Time",content:"1 action"},{title:"Range",content:"120 feet"},{title:"Components",content:"V, S"},{title:"Duration",content:"Instantaneous"},{title:"School",content:"Evocation"},{title:"Attack",content:"ranged"},{title:"Damage",content:"Force"}]},{id:"Subtitle",content:"Effect"},{id:"MultiText",content:["A beam of crackling energy streaks toward a creature within range. Make a ranged spell attack against the target. On a hit, the target takes 1d10 force damage. The spell creates more than one beam when you reach higher levels: two beams at 5th level, three beams at 11th level, and four beams at 17th level. You can direct the beams at the same target or at different ones. Make a separate attack roll for each beam."]},{id:"Table",content:[["character level","1","5","11","17"],["damage","1d10","1d10","1d10","1d10"]]}]}