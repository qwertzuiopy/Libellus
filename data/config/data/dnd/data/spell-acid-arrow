{id:"spell-acid-arrow",name:"Acid Arrow",content:[{id:"Title",content:"Acid Arrow"},{id:"StatGrid",content:[{title:"Level",content:"2"},{title:"Casting Time",content:"1 action"},{title:"Range",content:"90 feet"},{title:"Components",content:"V, S, M"},{title:"Duration",content:"Instantaneous"},{title:"School",content:"Evocation"},{title:"Attack",content:"ranged"},{title:"Damage",content:"Acid"}]},{id:"Subtitle",content:"Effect"},{id:"MultiText",content:["A shimmering green arrow streaks toward a target within range and bursts in a spray of acid. Make a ranged spell attack against the target. On a hit, the target takes 4d4 acid damage immediately and 2d4 acid damage at the end of its next turn. On a miss, the arrow splashes the target with acid for half as much of the initial damage and no damage at the end of its next turn."]},{id:"Subtitle",content:"At higher levels"},{id:"MultiText",content:["When you cast this spell using a spell slot of 3rd level or higher, the damage (both initial and later) increases by 1d4 for each slot level above 2nd."]},{id:"Table",content:[["slot level","2","3","4","5","6","7","8","9"],["damage","4d4","5d4","6d4","7d4","8d4","9d4","10d4","11d4"]]}]}