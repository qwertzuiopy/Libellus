{id:"spell-enthrall",name:"Enthrall",content:[{id:"Title",content:"Enthrall"},{id:"StatGrid",content:[{title:"Level",content:"2"},{title:"Casting Time",content:"1 action"},{title:"Range",content:"60 feet"},{title:"Components",content:"V, S"},{title:"Duration",content:"1 minute"},{title:"School",content:"Enchantment"},{title:"Save",content:"WIS Save"}]},{id:"Subtitle",content:"Effect"},{id:"MultiText",content:["You weave a distracting string of words, causing creatures of your choice that you can see within range and that can hear you to make a wisdom saving throw. Any creature that can't be charmed succeeds on this saving throw automatically, and if you or your companions are fighting a creature, it has advantage on the save. On a failed save, the target has disadvantage on Wisdom (Perception) checks made to perceive any creature other than you until the spell ends or until the target can no longer hear you. The spell ends if you are incapacitated or can no longer speak."]}]}