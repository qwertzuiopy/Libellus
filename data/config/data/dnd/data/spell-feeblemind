{id:"spell-feeblemind",name:"Feeblemind",content:[{id:"Title",content:"Feeblemind"},{id:"StatGrid",content:[{title:"Level",content:"8"},{title:"Casting Time",content:"1 action"},{title:"Range",content:"150 feet"},{title:"Components",content:"V, S, M"},{title:"Duration",content:"Instantaneous"},{title:"School",content:"Enchantment"},{title:"Save",content:"INT Save"},{title:"Damage",content:"Psychic"}]},{id:"Subtitle",content:"Effect"},{id:"MultiText",content:["You blast the mind of a creature that you can see within range, attempting to shatter its intellect and personality. The target takes 4d6 psychic damage and must make an intelligence saving throw.","On a failed save, the creature's Intelligence and Charisma scores become 1. The creature can't cast spells, activate magic items, understand language, or communicate in any intelligible way. The creature can, however, identify its friends, follow them, and even protect them.","At the end of every 30 days, the creature can repeat its saving throw against this spell. If it succeeds on its saving throw, the spell ends.","The spell can also be ended by greater restoration, heal, or wish."]},{id:"Table",content:[["slot level","8"],["damage","4d6"]]}]}