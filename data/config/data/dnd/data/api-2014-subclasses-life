{id:"api-2014-subclasses-life",name:"Life",content:[{id:"Title",content:"Life"},{id:"MultiText",content:["The Life domain focuses on the vibrant positive energy--one of the fundamental forces of the universe--that sustains all life. The gods of life promote vitality and health through healing the sick and wounded, caring for those in need, and driving away the forces of death and undeath. Almost any non-evil deity can claim influence over this domain, particularly agricultural deities, sun gods, gods of healing or endurance, and gods of home and community."]},{id:"Subtitle",content:"Features"},{id:"StatList",content:[{title:"1.",content:["@api-2014-features-bonus-proficiency","@api-2014-features-disciple-of-life"]},{title:"2.",content:["@api-2014-features-channel-divinity-preserve-life"]},{title:"6.",content:["@api-2014-features-blessed-healer"]},{title:"8.",content:["@api-2014-features-divine-strike"]},{title:"17.",content:["@api-2014-features-supreme-healing"]}]},{id:"LinkList",content:[{id:"api-2014-spells-bless",content:"level  1"},{id:"api-2014-spells-cure-wounds",content:"level  1"},{id:"api-2014-spells-lesser-restoration",content:"level  3"},{id:"api-2014-spells-spiritual-weapon",content:"level  3"},{id:"api-2014-spells-beacon-of-hope",content:"level  5"},{id:"api-2014-spells-revivify",content:"level  5"},{id:"api-2014-spells-death-ward",content:"level  7"},{id:"api-2014-spells-mass-cure-wounds",content:"level  9"},{id:"api-2014-spells-raise-dead",content:"level  9"}]}]}