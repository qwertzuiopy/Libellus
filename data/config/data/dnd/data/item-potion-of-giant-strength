{id:"item-potion-of-giant-strength",name:"Potion of Giant Strength",content:[{id:"Title",content:"Potion of Giant Strength"},{id:"StatGrid",content:[{title:"Category",content:"Potion"},{title:"Rarity",content:"Varies"}]},{id:"MultiText",content:["Potion, varies","When you drink this potion, your Strength score changes for 1 hour. The type of giant determines the score (see the table below). The potion has no effect on you if your Strength is equal to or greater than that score.","This potion's transparent liquid has floating in it a sliver of fingernail from a giant of the appropriate type. The potion of frost giant strength and the potion of stone giant strength have the same effect.","| Type of Giant | Strength | Rarity |","|---|---|---|","| Hill giant | 21 | Uncommon |","| Frost/stone giant | 23 | Rare |","| Fire giant | 25 | Rare |","| Cloud giant | 27 | Very rare |","| Storm giant | 29 | Legendary |"]},{id:"Subtitle",content:"Variants"},{id:"LinkList",content:[{id:"@potion-of-giant-strength-hill",content:""},{id:"@potion-of-giant-strength-frost",content:""},{id:"@potion-of-giant-strength-stone",content:""},{id:"@potion-of-giant-strength-fire",content:""},{id:"@potion-of-giant-strength-cloud",content:""},{id:"@potion-of-giant-strength-storm",content:""}]}]}