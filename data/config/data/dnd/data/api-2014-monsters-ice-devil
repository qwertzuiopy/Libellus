{id:"api-2014-monsters-ice-devil",name:"Ice Devil",category:"monster",content:[{id:"Title",content:"Ice Devil"},{id:"Image",url:"https://www.dnd5eapi.co/api/images/monsters/ice-devil.png"},{id:"StatGrid",content:[{title:"Strength",content:"21 / +5"},{title:"Dexterity",content:"14 / +2"},{title:"Constitution",content:"18 / +4"},{title:"Intelligence",content:"18 / +4"},{title:"Wisdom",content:"15 / +2"},{title:"Charisma",content:"18 / +4"},{title:"Alignment",content:"lawful evil"},{title:"Armor Class",content:"18"},{title:"Hit Dice",content:"19d10"},{title:"Type",content:"fiend"},{title:"Subtype",content:"devil"},{title:"Challenge Rating",content:"14"},{title:"Size",content:"Large"},{title:"Hit Points",content:"180 / 19d10+76"}]},{id:"StatList",content:[{title:"Speed",content:["40 ft. walk"]},{title:"Languages",content:["Infernal"," telepathy 120 ft."]},{title:"Senses",content:["blindsight 60 ft.","darkvision120 ft."]},{title:"Saving Throws",content:["+7 dex","+9 con","+7 wis","+9 cha"]},{title:"Skills",content:[]}]},{id:"Subtitle",content:"Abilities"},{id:"TitledText",content:[{title:"Devil's Sight",content:"Magical darkness doesn't impede the devil's darkvision."},{title:"Magic Resistance",content:"The devil has advantage on saving throws against spells and other magical effects."}]},{id:"Subtitle",content:"Actions"},{id:"TitledText",content:[{title:"Multiattack",content:"The devil makes three attacks: one with its bite, one with its claws, and one with its tail."},{title:"Bite",content:"Melee Weapon Attack: +10 to hit, reach 5 ft., one target. Hit: 12 (2d6 + 5) piercing damage plus 10 (3d6) cold damage."},{title:"Claws",content:"Melee Weapon Attack: +10 to hit, reach 5 ft., one target. Hit: 10 (2d4 + 5) slashing damage plus 10 (3d6) cold damage."},{title:"Tail",content:"Melee Weapon Attack: +10 to hit, reach 10 ft., one target. Hit: 12 (2d6 + 5) bludgeoning damage plus 10 (3d6) cold damage."},{title:"Wall of Ice",content:"The devil magically forms an opaque wall of ice on a solid surface it can see within 60 feet of it. The wall is 1 foot thick and up to 30 feet long and 10 feet high, or it's a hemispherical dome up to 20 feet in diameter.
When the wall appears, each creature in its space is pushed out of it by the shortest route. The creature chooses which side of the wall to end up on, unless the creature is incapacitated. The creature then makes a DC 17 Dexterity saving throw, taking 35 (10d6) cold damage on a failed save, or half as much damage on a successful one.
The wall lasts for 1 minute or until the devil is incapacitated or dies. The wall can be damaged and breached; each 10-foot section has AC 5, 30 hit points, vulnerability to fire damage, and immunity to acid, cold, necrotic, poison, and psychic damage. If a section is destroyed, it leaves behind a sheet of frigid air in the space the wall occupied. Whenever a creature finishes moving through the frigid air on a turn, willingly or otherwise, the creature must make a DC 17 Constitution saving throw, taking 17 (5d6) cold damage on a failed save, or half as much damage on a successful one. The frigid air dissipates when the rest of the wall vanishes."}]}]}