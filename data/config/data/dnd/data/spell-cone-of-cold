{id:"spell-cone-of-cold",name:"Cone of Cold",content:[{id:"Title",content:"Cone of Cold"},{id:"StatGrid",content:[{title:"Level",content:"5"},{title:"Casting Time",content:"1 action"},{title:"Range",content:"Self (60ft cone)"},{title:"Components",content:"V, S, M"},{title:"Duration",content:"Instantaneous"},{title:"School",content:"Evocation"},{title:"Save",content:"CON Save"},{title:"Damage",content:"Cold"}]},{id:"Subtitle",content:"Effect"},{id:"MultiText",content:["A blast of cold air erupts from your hands. Each creature in a 60-foot cone must make a constitution saving throw. A creature takes 8d8 cold damage on a failed save, or half as much damage on a successful one.","A creature killed by this spell becomes a frozen statue until it thaws."]},{id:"Subtitle",content:"At higher levels"},{id:"MultiText",content:["When you cast this spell using a spell slot of 6th level or higher, the damage increases by 1d8 for each slot level above 5th."]},{id:"Table",content:[["slot level","5","6","7","8","9"],["damage","8d8","9d8","10d8","11d8","12d8"]]}]}