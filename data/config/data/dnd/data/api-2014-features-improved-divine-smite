{id:"api-2014-features-improved-divine-smite",name:"Improved Divine Smite",content:[{id:"Title",content:"Improved Divine Smite"},{id:"StatGrid",content:[{title:"Level",content:"11"}]},{id:"MultiText",content:["By 11th level, you are so suffused with righteous might that all your melee weapon strikes carry divine power with them. Whenever you hit a creature with a melee weapon, the creature takes an extra 1d8 radiant damage. If you also use your Divine Smite with an attack, you add this damage to the extra damage of your Divine Smite."]},{id:"LinkList",content:[{id:"@api-2014-classes-paladin",content:""}]}]}