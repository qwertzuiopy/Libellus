{id:"spell-ice-storm",name:"Ice Storm",content:[{id:"Title",content:"Ice Storm"},{id:"StatGrid",content:[{title:"Level",content:"4"},{title:"Casting Time",content:"1 action"},{title:"Range",content:"300 feet (20ft cylinder)"},{title:"Components",content:"V, S, M"},{title:"Duration",content:"Instantaneous"},{title:"School",content:"Evocation"},{title:"Save",content:"DEX Save"},{title:"Damage",content:"Bludgeoning"}]},{id:"Subtitle",content:"Effect"},{id:"MultiText",content:["A hail of rock-hard ice pounds to the ground in a 20-foot-radius, 40-foot-high cylinder centered on a point within range. Each creature in the cylinder must make a dexterity saving throw. A creature takes 2d8 bludgeoning damage and 4d6 cold damage on a failed save, or half as much damage on a successful one.","Hailstones turn the storm's area of effect into difficult terrain until the end of your next turn."]},{id:"Subtitle",content:"At higher levels"},{id:"MultiText",content:["When you cast this spell using a spell slot of 5th level or higher, the bludgeoning damage increases by 1d8 for each slot level above 4th."]},{id:"Table",content:[["slot level","4","5","6","7","8","9"],["damage","2d8 + 4d6","3d8 + 4d6","4d8 + 4d6","5d8 + 4d6","6d8 + 4d6","7d8 + 4d6"]]}]}