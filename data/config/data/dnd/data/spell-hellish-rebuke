{id:"spell-hellish-rebuke",name:"Hellish Rebuke",content:[{id:"Title",content:"Hellish Rebuke"},{id:"StatGrid",content:[{title:"Level",content:"1"},{title:"Casting Time",content:"1 reaction"},{title:"Range",content:"60 feet"},{title:"Components",content:"V, S"},{title:"Duration",content:"Instantaneous"},{title:"School",content:"Evocation"},{title:"Save",content:"DEX Save"},{title:"Damage",content:"Fire"}]},{id:"Subtitle",content:"Effect"},{id:"MultiText",content:["You point your finger, and the creature that damaged you is momentarily surrounded by hellish flames. The creature must make a dexterity saving throw. It takes 2d10 fire damage on a failed save, or half as much damage on a successful one."]},{id:"Subtitle",content:"At higher levels"},{id:"MultiText",content:["When you cast this spell using a spell slot of 2nd level or higher, the damage increases by 1d10 for each slot level above 1st."]},{id:"Table",content:[["slot level","1","2","3","4","5","6","7","8","9"],["damage","2d10","3d10","4d10","5d10","6d10","7d10","8d10","9d10","10d10"]]}]}