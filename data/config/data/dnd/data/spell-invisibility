{id:"spell-invisibility",name:"Invisibility",content:[{id:"Title",content:"Invisibility"},{id:"StatGrid",content:[{title:"Level",content:"2"},{title:"Casting Time",content:"1 action"},{title:"Range",content:"Touch"},{title:"Components",content:"V, S, M"},{title:"Duration",content:"Up to 1 hour"},{title:"School",content:"Illusion"}]},{id:"Subtitle",content:"Effect"},{id:"MultiText",content:["A creature you touch becomes invisible until the spell ends. Anything the target is wearing or carrying is invisible as long as it is on the target's person. The spell ends for a target that attacks or casts a spell."]},{id:"Subtitle",content:"At higher levels"},{id:"MultiText",content:["When you cast this spell using a spell slot of 3rd level or higher, you can target one additional creature for each slot level above 2nd."]}]}