{id:"api-2014-subclasses-draconic",name:"Draconic",content:[{id:"Title",content:"Draconic"},{id:"MultiText",content:["Your innate magic comes from draconic magic that was mingled with your blood or that of your ancestors. Most often, sorcerers with this origin trace their descent back to a mighty sorcerer of ancient times who made a bargain with a dragon or who might even have claimed a dragon parent. Some of these bloodlines are well established in the world, but most are obscure. Any given sorcerer could be the first of a new bloodline, as a result of a pact or some other exceptional circumstance."]},{id:"Subtitle",content:"Features"},{id:"StatList",content:[{title:"1.",content:["@api-2014-features-dragon-ancestor","@api-2014-features-draconic-resilience"]},{title:"6.",content:["@api-2014-features-elemental-affinity"]},{title:"14.",content:["@api-2014-features-dragon-wings"]},{title:"18.",content:["@api-2014-features-draconic-presence"]}]}]}