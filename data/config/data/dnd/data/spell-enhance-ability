{id:"spell-enhance-ability",name:"Enhance Ability",content:[{id:"Title",content:"Enhance Ability"},{id:"StatGrid",content:[{title:"Level",content:"2"},{title:"Casting Time",content:"1 action"},{title:"Range",content:"Touch"},{title:"Components",content:"V, S, M"},{title:"Duration",content:"Up to 1 hour"},{title:"School",content:"Transmutation"}]},{id:"Subtitle",content:"Effect"},{id:"MultiText",content:["You touch a creature and bestow upon it a magical enhancement. Choose one of the following effects; the target gains that effect until the spell ends.","***Bear's Endurance.*** The target has advantage on constitution checks. It also gains 2d6 temporary hit points, which are lost when the spell ends.","***Bull's Strength.*** The target has advantage on strength checks, and his or her carrying capacity doubles.","***Cat's Grace.*** The target has advantage on dexterity checks. It also doesn't take damage from falling 20 feet or less if it isn't incapacitated.","***Eagle's Splendor.*** The target has advantage on Charisma checks.","***Fox's Cunning.*** The target has advantage on intelligence checks.","***Owl's Wisdom.*** The target has advantage on wisdom checks."]},{id:"Subtitle",content:"At higher levels"},{id:"MultiText",content:["When you cast this spell using a spell slot of 3rd level or higher, you can target one additional creature for each slot level above 2nd."]}]}