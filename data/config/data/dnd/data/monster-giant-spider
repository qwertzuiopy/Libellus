{id:"monster-giant-spider",name:"Giant Spider",category:"monster",content:[{id:"Title",content:"Giant Spider"},{id:"Image",url:"https://www.dnd5eapi.co/api/images/monsters/giant-spider.png"},{id:"StatGrid",content:[{title:"Strength",content:"14 / +2"},{title:"Dexterity",content:"16 / +3"},{title:"Constitution",content:"12 / +1"},{title:"Intelligence",content:"2 / -4"},{title:"Wisdom",content:"11 / 0"},{title:"Charisma",content:"4 / -3"},{title:"Alignment",content:"unaligned"},{title:"Armor Class",content:"14"},{title:"Hit Dice",content:"4d10"},{title:"Type",content:"beast"},{title:"Challenge Rating",content:"1"},{title:"Size",content:"Large"},{title:"Hit Points",content:"26 / 4d10+4"}]},{id:"StatList",content:[{title:"Speed",content:["30 ft. walk","30 ft. climb"]},{title:"Languages",content:[""]},{title:"Senses",content:["blindsight 10 ft.","darkvision60 ft."]},{title:"Saving Throws",content:[]},{title:"Skills",content:["+7 stealth"]}]},{id:"MultiText",content:["To snare its prey, a giant spider spins elaborate webs or shoots sticky strands of webbing from its abdomen. Giant spiders are most commonly found underground, making their lairs on ceilings or in dark, web-filled crevices. Such lairs are often festooned with web cocoons holding past victims."]},{id:"Subtitle",content:"Abilities"},{id:"TitledText",content:[{title:"Spider Climb",content:"The spider can climb difficult surfaces, including upside down on ceilings, without needing to make an ability check."},{title:"Web Sense",content:"While in contact with a web, the spider knows the exact location of any other creature in contact with the same web."},{title:"Web Walker",content:"The spider ignores movement restrictions caused by webbing."}]},{id:"Subtitle",content:"Actions"},{id:"TitledText",content:[{title:"Bite",content:"Melee Weapon Attack: +5 to hit, reach 5 ft., one creature. Hit: 7 (1d8 + 3) piercing damage, and the target must make a DC 11 Constitution saving throw, taking 9 (2d8) poison damage on a failed save, or half as much damage on a successful one. If the poison damage reduces the target to 0 hit points, the target is stable but poisoned for 1 hour, even after regaining hit points, and is paralyzed while poisoned in this way."},{title:"Web",content:"Ranged Weapon Attack: +5 to hit, range 30/60 ft., one creature. Hit: The target is restrained by webbing. As an action, the restrained target can make a DC 12 Strength check, bursting the webbing on a success. The webbing can also be attacked and destroyed (AC 10; hp 5; vulnerability to fire damage; immunity to bludgeoning, poison, and psychic damage)."}]}]}