{id:"api-2014-spells-silence",name:"Silence",content:[{id:"Title",content:"Silence"},{id:"StatGrid",content:[{title:"Level",content:"2"},{title:"Casting Time",content:"1 action"},{title:"Range",content:"120 feet (20ft sphere)"},{title:"Components",content:"V, S"},{title:"Duration",content:"Up to 10 minutes"},{title:"School",content:"Illusion"}]},{id:"Subtitle",content:"Effect"},{id:"MultiText",content:["For the duration, no sound can be created within or pass through a 20-foot-radius sphere centered on a point you choose within range. Any creature or object entirely inside the sphere is immune to thunder damage, and creatures are deafened while entirely inside it.","Casting a spell that includes a verbal component is impossible there."]}]}