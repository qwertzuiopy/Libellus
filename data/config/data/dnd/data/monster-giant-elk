{id:"monster-giant-elk",name:"Giant Elk",category:"monster",content:[{id:"Title",content:"Giant Elk"},{id:"Image",url:"https://www.dnd5eapi.co/api/images/monsters/giant-elk.png"},{id:"StatGrid",content:[{title:"Strength",content:"19 / +4"},{title:"Dexterity",content:"16 / +3"},{title:"Constitution",content:"14 / +2"},{title:"Intelligence",content:"7 / -2"},{title:"Wisdom",content:"14 / +2"},{title:"Charisma",content:"10 / 0"},{title:"Alignment",content:"unaligned"},{title:"Armor Class",content:"14"},{title:"Hit Dice",content:"5d12"},{title:"Type",content:"beast"},{title:"Challenge Rating",content:"2"},{title:"Size",content:"Huge"},{title:"Hit Points",content:"42 / 5d12+10"}]},{id:"StatList",content:[{title:"Speed",content:["60 ft. walk"]},{title:"Languages",content:["Giant Elk"," understands Common"," Elvish"," and Sylvan but can't speak"]},{title:"Senses",content:[]},{title:"Saving Throws",content:[]},{title:"Skills",content:["+4 perception"]}]},{id:"MultiText",content:["The majestic giant elk is rare to the point that its appearance is often taken as a foreshadowing of an important event, such as the birth of a king. Legends tell of gods that take the form of giant elk when visiting the Material Plane. Many cultures therefore believe that to hunt these creatures is to invite divine wrath."]},{id:"Subtitle",content:"Abilities"},{id:"TitledText",content:[{title:"Charge",content:"If the elk moves at least 20 ft. straight toward a target and then hits it with a ram attack on the same turn, the target takes an extra 7 (2d6) damage. If the target is a creature, it must succeed on a DC 14 Strength saving throw or be knocked prone."}]},{id:"Subtitle",content:"Actions"},{id:"TitledText",content:[{title:"Ram",content:"Melee Weapon Attack: +6 to hit, reach 10 ft., one target. Hit: 11 (2d6 + 4) bludgeoning damage."},{title:"Hooves",content:"Melee Weapon Attack: +6 to hit, reach 5 ft., one prone creature. Hit: 22 (4d8 + 4) bludgeoning damage."}]}]}