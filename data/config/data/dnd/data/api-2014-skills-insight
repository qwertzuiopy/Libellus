{id:"api-2014-skills-insight",name:"Insight",content:[{id:"Title",content:"Insight"},{id:"StatGrid",content:[{title:"Ability",content:"@api-2014-ability-scores-wis"}]},{id:"MultiText",content:["Your Wisdom (Insight) check decides whether you can determine the true intentions of a creature, such as when searching out a lie or predicting someone's next move. Doing so involves gleaning clues from body language, speech habits, and changes in mannerisms."]}]}