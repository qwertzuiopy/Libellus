using Gtk 4.0;
using Adw 1;

template $LibellusSourcesDialog : Adw.Dialog {
  content-width: 400;
  content-height: 100;
  Adw.ToolbarView {
    [top]
    Adw.HeaderBar {
    }
    Gtk.ListBox box {
      styles [
        "boxed-list",
      ]
      valign: start;
      selection-mode: none;
      margin-start: 12;
      margin-end: 12;
      margin-bottom: 12;
    }
  }
}